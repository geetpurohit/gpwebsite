---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Geet Purohit, Data Scientist',
  description = 'Geet Purohit is a Data Scientist at Verizon and a former astrophysicist, working on machine learning, explainable AI, and causal inference at billion-dollar scale.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://geetpurohit.com').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#020104" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Geet Purohit" />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="preload" href="/fonts/space-grotesk-700.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/outfit-400.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <slot />

    <script>
      const els = document.querySelectorAll('.reveal');
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && els.length) {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e, i) => {
            if (e.isIntersecting) {
              window.setTimeout(() => e.target.classList.add('visible'), Math.min(i, 5) * 70);
              io.unobserve(e.target);
            }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('visible'));
      }
    </script>
  </body>
</html>
