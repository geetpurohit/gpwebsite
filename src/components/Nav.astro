---
const links = [
  { href: '#about', label: 'About' },
  { href: '#experience', label: 'Experience' },
  { href: '#projects', label: 'Projects' },
  { href: '#skills', label: 'Skills' },
];
---

<nav id="nav">
  <a href="#top" class="logo" aria-label="Back to top">GP<span>.</span></a>

  <ul class="links">
    {links.map((l) => <li><a href={l.href} data-link={l.href}>{l.label}</a></li>)}
  </ul>

  <div class="nav-actions">
    <button class="motion" data-motion-toggle aria-pressed="false" title="Toggle animations site-wide">Motion: on</button>
    <a href="https://mail.google.com/mail/?view=cm&fs=1&to=geetp40@gmail.com" class="cta" target="_blank" rel="noopener noreferrer">Say hello →</a>
  </div>

  <button class="burger" id="burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile" id="mobile-menu" aria-hidden="true">
  {links.map((l) => <a href={l.href} data-mlink>{l.label}</a>)}
  <a href="https://mail.google.com/mail/?view=cm&fs=1&to=geetp40@gmail.com" class="mobile-cta" data-mlink target="_blank" rel="noopener noreferrer">Say hello →</a>
  <button class="motion mobile-motion" data-motion-toggle aria-pressed="false" title="Toggle animations site-wide">Motion: on</button>
</div>

<style>
  nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px var(--pad-x);
    border-bottom: 1px solid transparent;
    transition: background 0.35s var(--ease), border-color 0.35s var(--ease), padding 0.35s var(--ease);
  }
  nav.scrolled {
    background: rgba(5,3,8,0.72);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: var(--border-soft);
    padding-block: 11px;
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 20px;
    letter-spacing: -0.03em;
    color: var(--text);
  }
  .logo span { color: var(--purple); }

  .links {
    display: flex;
    gap: clamp(22px, 3vw, 40px);
    list-style: none;
    margin-inline: auto;
  }
  .links a {
    font-size: 14px;
    color: var(--muted);
    transition: color 0.25s;
  }
  .links a:hover,
  .links a.active { color: var(--text); }

  .nav-actions { display: flex; align-items: center; gap: 10px; }

  .cta {
    font-size: 13.5px;
    font-weight: 500;
    padding: 8px 18px;
    border-radius: var(--radius-pill);
    background: var(--purple);
    color: #fff;
    transition: filter 0.25s, transform 0.25s var(--ease);
    white-space: nowrap;
  }
  .cta:hover { filter: brightness(1.12); }

  .motion {
    font-family: var(--font-body);
    font-size: 13px;
    padding: 7px 14px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--border);
    background: none;
    color: var(--muted);
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.25s, border-color 0.25s;
  }
  .motion:hover { color: var(--text); border-color: rgba(168,85,247,0.4); }
  .mobile-motion { font-size: 14px !important; font-family: var(--font-body) !important; font-weight: 400; }

  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px 4px;
    z-index: 101;
  }
  .burger span {
    width: 24px; height: 1.6px;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.3s var(--ease), opacity 0.2s;
  }
  nav.menu-open .burger span:nth-child(1) { transform: translateY(6.6px) rotate(45deg); }
  nav.menu-open .burger span:nth-child(2) { opacity: 0; }
  nav.menu-open .burger span:nth-child(3) { transform: translateY(-6.6px) rotate(-45deg); }

  .mobile {
    position: fixed;
    inset: 0;
    z-index: 99;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 30px;
    background: rgba(5,3,8,0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s var(--ease);
  }
  .mobile.open { opacity: 1; pointer-events: auto; }
  .mobile a {
    font-family: var(--font-display);
    font-size: clamp(30px, 9vw, 42px);
    font-weight: 600;
    letter-spacing: -0.03em;
    color: var(--text-dim);
    transition: color 0.2s, transform 0.2s;
  }
  .mobile a:active { color: var(--purple-lt); }
  .mobile-cta {
    font-family: var(--font-body) !important;
    font-size: 16px !important;
    font-weight: 500;
    padding: 13px 32px;
    border-radius: var(--radius-pill);
    background: var(--purple);
    color: #fff !important;
    margin-top: 6px;
  }

  @media (max-width: 820px) {
    .links, .nav-actions { display: none; }
    .burger { display: flex; }
  }
</style>

<script>
  const nav = document.getElementById('nav');
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');

  // Site-wide animation kill-switch, persisted across visits. A reload is the
  // cleanest way to re-run every entrance animation consistently.
  const MOTION_KEY = 'gp-motion';
  const motionOff = localStorage.getItem(MOTION_KEY) === 'off';
  document.querySelectorAll<HTMLButtonElement>('[data-motion-toggle]').forEach((b) => {
    b.textContent = motionOff ? 'Motion: off' : 'Motion: on';
    b.setAttribute('aria-pressed', String(motionOff));
    b.addEventListener('click', () => {
      localStorage.setItem(MOTION_KEY, motionOff ? 'on' : 'off');
      location.reload();
    });
  });

  const onScroll = () => nav?.classList.toggle('scrolled', window.scrollY > 36);
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  const setMenu = (open: boolean) => {
    nav?.classList.toggle('menu-open', open);
    menu?.classList.toggle('open', open);
    burger?.setAttribute('aria-expanded', String(open));
    menu?.setAttribute('aria-hidden', String(!open));
    document.body.style.overflow = open ? 'hidden' : '';
  };
  burger?.addEventListener('click', () => setMenu(!menu?.classList.contains('open')));
  menu?.querySelectorAll('[data-mlink]').forEach((a) => a.addEventListener('click', () => setMenu(false)));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setMenu(false); });

  const navLinks = Array.from(document.querySelectorAll('[data-link]')) as HTMLAnchorElement[];
  const byId = new Map(navLinks.map((a) => [a.getAttribute('data-link')!.slice(1), a]));
  const spy = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        navLinks.forEach((a) => a.classList.remove('active'));
        byId.get(e.target.id)?.classList.add('active');
      }
    });
  }, { rootMargin: '-45% 0px -50% 0px' });
  ['about', 'experience', 'projects', 'skills'].forEach((id) => {
    const el = document.getElementById(id);
    if (el) spy.observe(el);
  });
</script>
