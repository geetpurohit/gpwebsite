---
const pills = ['Python', 'SQL', 'TensorFlow', 'GCP / BigQuery', 'Streamlit', 'DataRobot', 'Apache Spark', 'Docker', 'Tableau', 'Java'];
const facts = [
  {
    icon: '🌌',
    title: 'Dual B.S. in Astrophysics & CS',
    body: 'Rutgers University, 3.7 GPA. Society of Physics member, minor in Mathematics. The kind of person who thinks statistical mechanics was just ML before it was cool.',
  },
  {
    icon: '📡',
    title: 'Hosted the Verizon Analytics Summit',
    body: 'Presented at the 2023 summit alongside executives from Verizon, Bayer, BNY Mellon, NY Life, and ThoughtSpot. No pressure.',
  },
  {
    icon: '🧬',
    title: 'Trained ML on mice',
    body: 'At the Human Genetics Institute of NJ, built DeepLabCut models for kinematic pose estimation on wet-lab video. Yes, really.',
  },
  {
    icon: '🎓',
    title: 'Georgia Tech MS in Computational Analytics',
    body: 'My honest stance on the degree: check back in 3 years to see if I actually get that 4.0.',
  },
];
---

<section id="about" class="section">
  <div class="container about-grid">
    <div class="about-left reveal">
      <span class="section-label">About</span>
      <h2 class="section-title">The person<br>behind the models</h2>
      <p class="body">
        I'm Geet, a Data Scientist at Verizon who started out studying black holes at Rutgers
        and somehow ended up finding anomalies in billion-dollar datasets instead.
        <strong>Turns out the universe is full of patterns whether you're looking at galaxies or customer churn.</strong>
      </p>
      <p class="body">
        I'm currently a few semesters into my Georgia Tech Master's in Computational Analytics,
        hanging in there by a <s>thread</s> token, but still going.
      </p>
      <p class="body">
        Outside of work: unhealthy amounts of anime, losing LP in League of Legends,
        and occasionally remembering to touch grass.
      </p>
      <div class="pills">
        {pills.map((p) => <span class="pill">{p}</span>)}
      </div>
    </div>

    <div class="about-right">
      <div class="facts">
        {facts.map((f) => (
          <article class="fact reveal interactive">
            <span class="fact-icon">{f.icon}</span>
            <h3 class="fact-title">{f.title}</h3>
            <p class="fact-body">{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  #about { border-top: 1px solid var(--border-soft); }
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(40px, 6vw, 84px);
    align-items: start;
  }
  .body {
    font-size: clamp(16.5px, 1.25vw, 18.5px);
    color: var(--text-dim);
    font-weight: 300;
    line-height: 1.85;
    margin-bottom: 22px;
  }
  .body strong { color: var(--text); font-weight: 500; }
  .body s { color: var(--muted); }

  .pills { display: flex; flex-wrap: wrap; gap: 9px; margin-top: 28px; }
  .pill {
    font-size: 12.5px;
    padding: 6px 15px;
    border-radius: 7px;
    background: rgba(255,255,255,0.025);
    border: 1px solid var(--border);
    color: var(--text-dim);
    transition: border-color 0.25s, color 0.25s, background 0.25s;
  }
  .pill:hover { border-color: rgba(168,85,247,0.4); color: var(--lilac); background: rgba(168,85,247,0.05); }

  .facts { display: flex; flex-direction: column; gap: 16px; }
  .fact {
    position: relative;
    padding: 24px 26px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: linear-gradient(160deg, rgba(255,255,255,0.025), rgba(168,85,247,0.012));
    transition: border-color 0.3s, transform 0.3s, background 0.3s;
  }
  .fact:hover {
    border-color: rgba(168,85,247,0.35);
    transform: translateY(-3px);
    background: linear-gradient(160deg, rgba(168,85,247,0.07), rgba(124,58,237,0.03));
  }
  .fact-icon { font-size: 22px; display: block; margin-bottom: 12px; }
  .fact-title {
    font-family: var(--font-display);
    font-size: 16.5px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 7px;
  }
  .fact-body { font-size: 15px; color: var(--text-dim); font-weight: 300; line-height: 1.68; }

  @media (max-width: 820px) {
    .about-grid { grid-template-columns: 1fr; }
  }
</style>
