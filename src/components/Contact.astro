<style>
  #contact {
    position: relative;
    border-top: 1px solid var(--border);
    text-align: center;
    overflow: hidden;
  }
  .glow {
    position: absolute;
    top: 30%; left: 50%;
    width: 620px; height: 520px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(168,85,247,0.16), transparent 65%);
    filter: blur(40px);
    pointer-events: none;
  }
  .inner { position: relative; z-index: 1; max-width: 600px; }

  .contact-title {
    font-family: var(--font-display);
    font-size: clamp(40px, 6.5vw, 76px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.03;
    margin-bottom: 20px;
  }
  .contact-sub {
    font-size: clamp(17px, 1.4vw, 20px);
    color: var(--text-dim);
    font-weight: 300;
    line-height: 1.6;
    margin-bottom: 36px;
  }
  .email {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(21px, 3vw, 28px);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 36px;
    transition: color 0.25s;
    word-break: break-word;
  }
  .email:hover { color: var(--purple-lt); }

  .links { display: flex; justify-content: center; flex-wrap: wrap; gap: 12px; }
  .link {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 12px 26px;
    border-radius: var(--radius-pill);
    background: var(--surface);
    color: var(--text-dim);
    font-size: 15px;
    font-weight: 500;
    transition: color 0.25s, background 0.25s, transform 0.25s var(--ease);
  }
  .link:hover {
    color: var(--text);
    background: var(--surface-hover);
    transform: translateY(-2px);
  }
</style>
