---
---

<div id="ow-overlay" role="dialog" aria-modal="true" aria-label="Eye of the Universe" aria-hidden="true">
  <canvas id="ow-stars" aria-hidden="true"></canvas>
  <button class="ow-close" id="ow-close">esc / close</button>
  <img class="ow-symbol" src="/Eye_Symbol.webp" alt="Eye of the Universe" draggable="false" />
  <div class="ow-text">
    <div class="ow-studio">Mobius Digital</div>
    <p class="ow-quote">As a child, I considered such unknowns sinister. Now, though, I understand they bear no ill will. The universe is, and we are.</p>
    <div class="ow-solanum">Solanum</div>
    <div class="ow-game">Outer Wilds</div>
  </div>
  <audio id="ow-audio" src="/eotu-solanum.mp3" loop preload="none"></audio>
</div>

<style>
  #ow-overlay {
    position: fixed;
    inset: 0;
    z-index: 100000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: #000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 1.1s ease;
    overflow: hidden;
  }
  #ow-overlay.open { opacity: 1; pointer-events: auto; }

  #ow-overlay::before {
    content: '';
    position: absolute;
    width: 580px; height: 500px;
    top: 37%; left: 50%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, #7525d0 0%, #3a0f82 45%, #160840 100%);
    border-radius: 50%;
    filter: blur(120px);
    animation: owAmbient 14s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes owAmbient {
    0%, 100% { opacity: 0;   transform: translate(-50%, -50%) scale(0.85); }
    50%      { opacity: 0.4; transform: translate(-50%, -50%) scale(1.12); }
  }
  #ow-overlay::after {
    content: '';
    position: absolute; inset: 0;
    z-index: 5;
    opacity: 0.035;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 180px 180px;
  }

  #ow-stars { position: absolute; inset: 0; z-index: 1; pointer-events: none; }

  .ow-symbol {
    position: relative;
    z-index: 2;
    width: clamp(220px, 38vw, 360px);
    height: clamp(220px, 38vw, 360px);
    object-fit: contain;
    margin-bottom: 38px;
    animation: owRevolve 38s linear infinite, owGlow 6s ease-in-out infinite;
    filter:
      sepia(1) hue-rotate(252deg) saturate(4) brightness(0.8)
      drop-shadow(0 0 22px rgba(168,85,247,0.95))
      drop-shadow(0 0 70px rgba(110,40,210,0.45));
  }
  @keyframes owRevolve { to { transform: rotate(360deg); } }
  @keyframes owGlow {
    0%, 100% { filter: sepia(1) hue-rotate(252deg) saturate(4) brightness(0.76) drop-shadow(0 0 18px rgba(160,80,255,0.9)) drop-shadow(0 0 65px rgba(100,40,200,0.4)); }
    50%      { filter: sepia(1) hue-rotate(252deg) saturate(4) brightness(0.94) drop-shadow(0 0 30px rgba(180,100,255,1))  drop-shadow(0 0 90px rgba(120,55,220,0.55)); }
  }

  .ow-text {
    position: relative;
    z-index: 2;
    text-align: center;
    width: min(600px, 88vw);
    opacity: 0;
    animation: owFadeUp 1.8s ease forwards 0.5s;
  }
  @keyframes owFadeUp { from { opacity: 0; transform: translateY(22px); } to { opacity: 1; transform: none; } }

  .ow-studio {
    font-family: 'Brandon Grotesque', Georgia, serif;
    font-weight: 900; font-size: 10px;
    letter-spacing: 0.5em; text-transform: uppercase;
    color: rgba(190,140,255,0.4);
    margin-bottom: 24px;
  }
  .ow-quote {
    font-family: 'Brandon Grotesque', Georgia, serif;
    font-weight: 300;
    font-size: clamp(17px, 2.4vw, 25px);
    color: rgba(222,206,255,0.86);
    line-height: 1.95;
    letter-spacing: 0.01em;
  }
  .ow-solanum {
    font-family: 'Brandon Grotesque', sans-serif;
    font-weight: 300; font-size: 13px;
    letter-spacing: 0.22em; text-transform: uppercase;
    color: rgba(190,140,255,0.4);
    margin-top: 20px;
  }
  .ow-game {
    font-family: 'Brandon Grotesque', sans-serif;
    font-weight: 900; font-size: 9px;
    letter-spacing: 0.5em; text-transform: uppercase;
    color: rgba(190,140,255,0.24);
    margin-top: 6px;
  }
  .ow-close {
    position: absolute;
    top: 28px; right: 32px;
    z-index: 6;
    background: none; border: none; cursor: pointer;
    font-family: 'Brandon Grotesque', var(--font-body);
    font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase;
    color: rgba(255,255,255,0.18);
    transition: color 0.3s;
  }
  .ow-close:hover { color: rgba(190,140,255,0.6); }
</style>

<script>
  const overlay = document.getElementById('ow-overlay');
  const trigger = document.getElementById('ow-trigger');
  const close = document.getElementById('ow-close');
  const audio = document.getElementById('ow-audio') as HTMLAudioElement | null;
  const canvas = document.getElementById('ow-stars') as HTMLCanvasElement | null;

  let starsRaf = 0;
  let starsInit = false;
  let starsOn = false;
  let drawStars: (t: number) => void = () => {};

  function initStars() {
    if (!canvas) return;
    const ctx = canvas.getContext('2d')!;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0, h = 0;
    const resize = () => {
      w = window.innerWidth; h = window.innerHeight;
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener('resize', resize);
    const stars = Array.from({ length: 220 }, () => ({
      x: Math.random() * window.innerWidth,
      y: Math.random() * window.innerHeight,
      r: Math.random() * 1.3 + 0.2,
      p: Math.random() * Math.PI * 2,
      s: Math.random() * 0.004 + 0.001,
    }));
    drawStars = (t: number) => {
      ctx.clearRect(0, 0, w, h);
      for (const st of stars) {
        const a = 0.25 + 0.55 * Math.sin(st.p + t * st.s);
        ctx.beginPath();
        ctx.arc(st.x, st.y, st.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(210,190,255,${Math.max(0, a)})`;
        ctx.fill();
      }
    };
    starsInit = true;
  }

  function starsStart() {
    if (!canvas) return;
    if (!starsInit) initStars();
    if (starsOn) return;
    starsOn = true;
    const loop = (t: number) => {
      if (!starsOn) return;
      drawStars(t);
      starsRaf = requestAnimationFrame(loop);
    };
    starsRaf = requestAnimationFrame(loop);
  }
  function starsStop() { starsOn = false; cancelAnimationFrame(starsRaf); }

  let fontsLoaded = false;
  function loadEggFonts() {
    if (fontsLoaded) return;
    fontsLoaded = true;
    const weights: [number, string][] = [
      [300, 'light-BF64a625c93e709'],
      [400, 'regular-BF64a625c9311e1'],
      [500, 'medium-BF64a625c84a521'],
      [700, 'bold-BF64a625c9151d5'],
      [900, 'black-BF64a625c944b08'],
    ];
    const style = document.createElement('style');
    style.textContent = weights.map(([wt, file]) =>
      `@font-face{font-family:'Brandon Grotesque';font-weight:${wt};font-style:normal;font-display:swap;src:url('/fonts/HvDTrial_Brandon_Grotesque_${file}.otf') format('opentype')}`
    ).join('');
    document.head.appendChild(style);
  }

  const open = () => {
    if (!overlay) return;
    loadEggFonts();
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    starsStart();
    if (audio) { audio.volume = 0.0; audio.play().then(() => fade(audio, 0.55, 2500)).catch(() => {}); }
  };
  const shut = () => {
    if (!overlay) return;
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
    starsStop();
    if (audio) fade(audio, 0, 800, () => audio.pause());
  };

  function fade(el: HTMLAudioElement, to: number, ms: number, done?: () => void) {
    const from = el.volume;
    const start = performance.now();
    const step = (now: number) => {
      const k = Math.min(1, (now - start) / ms);
      el.volume = Math.max(0, Math.min(1, from + (to - from) * k));
      if (k < 1) requestAnimationFrame(step); else done?.();
    };
    requestAnimationFrame(step);
  }

  trigger?.addEventListener('click', open);
  close?.addEventListener('click', shut);
  overlay?.addEventListener('click', (e) => { if (e.target === overlay) shut(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') shut(); });
</script>
