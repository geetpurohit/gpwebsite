---
---

<canvas id="starfield" aria-hidden="true"></canvas>

<style>
  #starfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(58% 48% at 80% 10%, rgba(109,40,217,0.09), transparent 68%),
      radial-gradient(52% 44% at 10% 90%, rgba(124,58,237,0.06), transparent 70%),
      #020104;
  }
</style>

<script>
  type Star = { x: number; y: number; z: number; r: number; base: number; tw: number; phase: number; hue: number };
  type Comet = { x: number; y: number; vx: number; vy: number; len: number };
  type Spark = { ang: number; sp: number };
  type Nova = { x: number; y: number; t: number; max: number; sparks: Spark[] };
  type Hole = { x: number; y: number; vx?: number; vy?: number; R: number; E: number };

  const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
  if (canvas) {
    const ctx = canvas.getContext('2d', { alpha: true })!;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      || document.documentElement.classList.contains('no-motion');
    const fine = window.matchMedia('(pointer: fine)').matches;
    const TAU = Math.PI * 2;

    let W = 0, H = 0, dpr = 1;
    let stars: Star[] = [];
    let comets: Comet[] = [];
    let novae: Nova[] = [];
    let roamers: Hole[] = [];
    let raf = 0, last = performance.now(), running = true;

    let ppx = 0, ppy = 0, ptx = 0, pty = 0;
    let scrollY = window.scrollY || 0;

    let mainX = 0, mainBaseY = 0, mainR = 0, mainE = 0;

    let tComet = 4000, tNova = 8000, tRoam = 5000;

    const tints = [
      [255, 255, 255],
      [232, 226, 255],
      [205, 186, 255],
      [216, 180, 254],
      [232, 121, 249],
    ];

    function build() {
      dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      W = window.innerWidth;
      H = window.innerHeight;
      canvas!.width = Math.floor(W * dpr);
      canvas!.height = Math.floor(H * dpr);
      canvas!.style.width = W + 'px';
      canvas!.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const mobile = W < 820;
      mainX = W * (mobile ? 0.74 : 0.76);
      mainBaseY = H * 0.52;
      mainR = Math.max(58, Math.min(W, H) * (mobile ? 0.13 : 0.14));
      mainE = mainR * 1.9;

      const count = Math.min(420, Math.max(110, Math.round((W * H) / 5200)));
      stars = Array.from({ length: count }, () => {
        const z = Math.random();
        return {
          x: Math.random() * W,
          y: Math.random() * H,
          z,
          r: (0.4 + z * 1.5) * (0.7 + Math.random() * 0.8),
          base: 0.22 + Math.random() * 0.5,
          tw: 0.5 + Math.random() * 1.4,
          phase: Math.random() * TAU,
          hue: Math.random() < 0.16 ? 1 + Math.floor(Math.random() * 4) : 0,
        };
      });

    }

    function dot(x: number, y: number, r: number, a: number, tint: number[]) {
      if (a <= 0.02) return;
      ctx.fillStyle = `rgba(${tint[0]},${tint[1]},${tint[2]},${Math.min(1, a)})`;
      ctx.beginPath();
      ctx.arc(x, y, r, 0, TAU);
      ctx.fill();
    }

    function lensDelta(x: number, y: number, holes: Hole[]): [number, number] {
      let dx = 0, dy = 0;
      for (const h of holes) {
        const rx = x - h.x, ry = y - h.y;
        const beta = Math.hypot(rx, ry);
        const E = h.E, outer = E * 4.5, inner = E * 2.6;
        if (beta >= outer) continue;
        let w = 1;
        if (beta > inner) { const t = (beta - inner) / (outer - inner); w = 1 - t * t * (3 - 2 * t); }
        const delta = 0.5 * (Math.sqrt(beta * beta + 4 * E * E) - beta) * w;
        dx += (rx / (beta || 1)) * delta;
        dy += (ry / (beta || 1)) * delta;
      }
      return [dx, dy];
    }

    function lensedRing(cx0: number, cy0: number, r: number, holes: Hole[], stroke: string, lw: number) {
      ctx.strokeStyle = stroke;
      ctx.lineWidth = lw;
      ctx.beginPath();
      const N = 56;
      for (let i = 0; i <= N; i++) {
        const ang = (i / N) * TAU;
        const px = cx0 + Math.cos(ang) * r, py = cy0 + Math.sin(ang) * r;
        const [ex, ey] = lensDelta(px, py, holes);
        const X = px + ex, Y = py + ey;
        if (i === 0) ctx.moveTo(X, Y); else ctx.lineTo(X, Y);
      }
      ctx.stroke();
    }

    function drawStars(now: number, holes: Hole[]) {
      for (const s of stars) {
        const depth = 0.4 + s.z * 1.6;
        const ox = s.x + ppx * depth;
        const oy = s.y + ppy * depth;
        const twinkle = reduce ? 1 : s.base + Math.sin(now * 0.0016 * s.tw + s.phase) * 0.95 * s.base + 0.1;
        let a = Math.max(0, Math.min(1, twinkle));
        const tint = tints[s.hue];

        let dx = 0, dy = 0, mag = 1;
        for (const h of holes) {
          const rx = ox - h.x, ry = oy - h.y;
          const beta = Math.hypot(rx, ry);
          const E = h.E, outer = E * 4.5, inner = E * 2.6;
          if (beta >= outer) continue;
          let w = 1;
          if (beta > inner) { const t = (beta - inner) / (outer - inner); w = 1 - t * t * (3 - 2 * t); }
          const ux = rx / (beta || 1), uy = ry / (beta || 1);
          const delta = 0.5 * (Math.sqrt(beta * beta + 4 * E * E) - beta) * w;
          dx += ux * delta; dy += uy * delta;
          const u = Math.max(beta / E, 1e-4), rt = Math.sqrt(u * u + 4);
          const muP = 0.5 * ((u * u + 2) / (u * rt) + 1);
          mag *= 1 + (Math.min(muP, 3) - 1) * w;
        }

        const x = ox + dx, y = oy + dy;
        a = Math.min(1, a * Math.min(mag, 3.5));
        dot(x, y, s.r, a, tint);
        if (s.r > 1.3 && a > 0.62) dot(x, y, s.r * 2.4, (a - 0.62) * 0.4, tint);
      }
    }

    function drawHoleShape(x: number, y: number, R: number) {
      const glow = ctx.createRadialGradient(x, y, R * 0.9, x, y, R * 1.7);
      glow.addColorStop(0, 'rgba(0,0,0,0)');
      glow.addColorStop(0.4, 'rgba(150,92,235,0.18)');
      glow.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = glow;
      ctx.beginPath(); ctx.arc(x, y, R * 1.7, 0, TAU); ctx.fill();

      ctx.fillStyle = '#000';
      ctx.beginPath(); ctx.arc(x, y, R, 0, TAU); ctx.fill();

      ctx.save();
      ctx.globalCompositeOperation = 'lighter';
      ctx.lineWidth = Math.max(3, R * 0.12);
      ctx.strokeStyle = 'rgba(150,92,235,0.4)';
      ctx.beginPath(); ctx.arc(x, y, R * 1.05, 0, TAU); ctx.stroke();
      ctx.lineWidth = Math.max(1.2, R * 0.03);
      ctx.strokeStyle = 'rgba(245,238,255,0.95)';
      ctx.beginPath(); ctx.arc(x, y, R * 1.015, 0, TAU); ctx.stroke();
      ctx.restore();
    }

    function drawComets() {
      for (let i = comets.length - 1; i >= 0; i--) {
        const c = comets[i];
        c.x += c.vx; c.y += c.vy;
        if (c.x > W + 140 || c.y > H + 140 || c.x < -140 || c.y < -140) { comets.splice(i, 1); continue; }
        const tx = c.x - c.vx * (c.len / 12), ty = c.y - c.vy * (c.len / 12);
        const g = ctx.createLinearGradient(c.x, c.y, tx, ty);
        g.addColorStop(0, 'rgba(245,240,255,0.95)');
        g.addColorStop(0.35, 'rgba(200,160,255,0.4)');
        g.addColorStop(1, 'rgba(168,85,247,0)');
        ctx.strokeStyle = g;
        ctx.lineWidth = 2.2;
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(c.x, c.y);
        ctx.lineTo(tx, ty);
        ctx.stroke();
        dot(c.x, c.y, 2, 0.95, [248, 244, 255]);
      }
    }

    function drawNovae(dt: number, holes: Hole[]) {
      for (let i = novae.length - 1; i >= 0; i--) {
        const n = novae[i];
        n.t += dt;
        const age = n.t / 3200;
        if (age >= 1) { novae.splice(i, 1); continue; }
        const ease = 1 - Math.pow(1 - age, 2.2);
        const fade = 1 - age;

        const [cdx, cdy] = lensDelta(n.x, n.y, holes);
        const cx0 = n.x + cdx, cy0 = n.y + cdy;

        const coreA = Math.max(0, 1 - age * 1.7);
        if (coreA > 0.02) {
          const cr = 3 + age * 18;
          const cg = ctx.createRadialGradient(cx0, cy0, 0, cx0, cy0, cr * 3);
          cg.addColorStop(0, `rgba(255,255,255,${coreA})`);
          cg.addColorStop(0.3, `rgba(245,228,255,${coreA * 0.8})`);
          cg.addColorStop(0.6, `rgba(232,121,249,${coreA * 0.4})`);
          cg.addColorStop(1, 'rgba(168,85,247,0)');
          ctx.fillStyle = cg;
          ctx.beginPath(); ctx.arc(cx0, cy0, cr * 3, 0, TAU); ctx.fill();

          ctx.save();
          ctx.translate(cx0, cy0);
          ctx.globalAlpha = coreA * 0.85;
          ctx.strokeStyle = 'rgba(255,246,255,0.9)';
          ctx.lineWidth = 1.4;
          ctx.lineCap = 'round';
          for (let k = 0; k < 6; k++) {
            const ang = k * (Math.PI / 3) + age * 0.6;
            const len = cr * (4 + Math.sin(k) * 0.6);
            ctx.beginPath();
            ctx.moveTo(0, 0);
            ctx.lineTo(Math.cos(ang) * len, Math.sin(ang) * len);
            ctx.stroke();
          }
          ctx.restore();
          ctx.globalAlpha = 1;
        }

        lensedRing(n.x, n.y, ease * n.max, holes, `rgba(236,214,255,${fade * 0.6})`, Math.max(0.6, 3.5 * fade));
        lensedRing(n.x, n.y, ease * n.max * 0.62, holes, `rgba(255,150,240,${fade * 0.4})`, Math.max(0.5, 2 * fade));

        for (const sp of n.sparks) {
          const d = ease * n.max * sp.sp;
          const px = n.x + Math.cos(sp.ang) * d, py = n.y + Math.sin(sp.ang) * d;
          const [ex, ey] = lensDelta(px, py, holes);
          dot(px + ex, py + ey, Math.max(0.6, 1.8 * fade), fade * 0.85, [255, 240, 255]);
        }
      }
    }

    function spawnComet() {
      const fromLeft = Math.random() < 0.5;
      const x = fromLeft ? -60 : Math.random() * W * 0.5;
      const y = fromLeft ? Math.random() * H * 0.4 : -60;
      const ang = Math.PI / 4 + (Math.random() - 0.5) * 0.5;
      const sp = 8 + Math.random() * 6;
      comets.push({ x, y, vx: Math.cos(ang) * sp, vy: Math.sin(ang) * sp, len: 90 + Math.random() * 130 });
    }

    function spawnNova() {
      const s = stars[(Math.random() * stars.length) | 0];
      if (!s) return;
      const n = 10 + ((Math.random() * 8) | 0);
      const sparks: Spark[] = Array.from({ length: n }, () => ({ ang: Math.random() * TAU, sp: 0.55 + Math.random() * 0.5 }));
      novae.push({ x: s.x, y: s.y, t: 0, max: 130 + Math.random() * 140, sparks });
    }

    function spawnRoamer() {
      const R = Math.max(22, Math.min(W, H) * 0.038);
      const m = R * 5;
      const edge = (Math.random() * 4) | 0;
      let x = 0, y = 0;
      if (edge === 0) { x = -m; y = Math.random() * H; }
      else if (edge === 1) { x = W + m; y = Math.random() * H; }
      else if (edge === 2) { x = Math.random() * W; y = -m; }
      else { x = Math.random() * W; y = H + m; }
      const tx = W * (0.2 + Math.random() * 0.6), ty = H * (0.2 + Math.random() * 0.6);
      const ang = Math.atan2(ty - y, tx - x) + (Math.random() - 0.5) * 0.5;
      const dur = 11000 + Math.random() * 8000;
      const sp = (Math.hypot(W, H) + m * 2) / dur;
      roamers.push({ x, y, vx: Math.cos(ang) * sp, vy: Math.sin(ang) * sp, R, E: R * 2.4 });
    }

    function frame(now: number) {
      const dt = Math.min(now - last, 50);
      last = now;
      ctx.clearRect(0, 0, W, H);

      ppx += (ptx - ppx) * 0.05;
      ppy += (pty - ppy) * 0.05;

      const mainY = mainBaseY - scrollY;
      const mainOn = mainY > -mainR * 5 && mainY < H + mainR * 5;

      if (!reduce) {
        for (let i = roamers.length - 1; i >= 0; i--) {
          const r = roamers[i];
          r.x += r.vx * dt; r.y += r.vy * dt;
          const m = r.E * 5;
          if (r.x < -m || r.x > W + m || r.y < -m || r.y > H + m) roamers.splice(i, 1);
        }
      }

      const holes: Hole[] = roamers.slice();
      if (mainOn) holes.push({ x: mainX, y: mainY, R: mainR, E: mainE });

      drawStars(now, holes);

      ctx.globalCompositeOperation = 'lighter';
      drawNovae(dt, holes);
      drawComets();
      ctx.globalCompositeOperation = 'source-over';

      for (const r of roamers) drawHoleShape(r.x, r.y, r.R);
      if (mainOn) drawHoleShape(mainX, mainY, mainR);

      (window as any).__bhs = holes;

      if (!reduce) {
        tComet -= dt; tNova -= dt; tRoam -= dt;
        if (tComet <= 0) { spawnComet(); tComet = 6000 + Math.random() * 9000; }
        if (tNova <= 0) { spawnNova(); tNova = 8000 + Math.random() * 11000; }
        if (tRoam <= 0 && roamers.length < 2) { spawnRoamer(); tRoam = 9000 + Math.random() * 12000; }
      }

      if (running) raf = requestAnimationFrame(frame);
    }

    function start() { if (!running) { running = true; last = performance.now(); raf = requestAnimationFrame(frame); } }
    function stop() { running = false; cancelAnimationFrame(raf); }

    if (fine) {
      window.addEventListener('pointermove', (e) => {
        ptx = (e.clientX / W - 0.5) * 16;
        pty = (e.clientY / H - 0.5) * 16;
      }, { passive: true });
    }
    window.addEventListener('scroll', () => { scrollY = window.scrollY || 0; }, { passive: true });

    document.addEventListener('visibilitychange', () => { if (document.hidden) stop(); else start(); });

    let rt: number;
    window.addEventListener('resize', () => { clearTimeout(rt); rt = window.setTimeout(build, 150); });

    build();
    raf = requestAnimationFrame(frame);
  }
</script>
