---
const demos = [
  {
    title: 'Triage: Clinical-Note Routing',
    hook: 'Read a medical note',
    img: '/projects/shots/triage.jpg',
    href: '/projects/triage',
  },
  {
    title: 'Credit-Default Scorecard',
    hook: 'Score an applicant',
    img: '/projects/shots/credit-risk.jpg',
    href: '/projects/credit-risk',
  },
  {
    title: 'AreYouBlinking',
    hook: 'Speak in blinks',
    img: '/projects/shots/blink.jpg',
    href: '/projects/blink',
  },
  {
    title: 'Mapping the Known Universe',
    hook: 'Fly the cosmos',
    img: '/projects/shots/universe.jpg',
    href: '/projects/universe',
  },
  {
    title: 'Gravitational Microlensing',
    hook: 'Warp spacetime',
    img: '/projects/shots/microlensing.jpg',
    href: '/projects/microlensing',
  },
  {
    title: 'Uplift Modeling',
    hook: 'Find the persuadables',
    img: '/projects/shots/uplift.jpg',
    href: '/projects/uplift',
  },
  {
    title: 'Significance',
    hook: 'Design honest experiments',
    img: '/projects/shots/experiment.jpg',
    href: '/projects/experiment',
  },
];

const rest = [
  {
    category: 'Work',
    title: 'Credit Risk Intelligence Platform',
    desc: 'Fullstack app that synthetically generates customer databases to monitor credit-policy changes and their downstream impact on bad-debt writeoff. Built end-to-end (data pipeline, ML models, and a Streamlit frontend) so finance teams can simulate policy scenarios without ever touching production data.',
    metric: '$1.2B+',
    metricLabel: 'in bad debt monitored',
  },
  {
    category: 'Work',
    title: 'XAI Gross-Adds Framework',
    desc: 'Explainable-AI framework isolating the real-time drivers of Verizon Gross Adds. Cut hypothesis-generation time by 73% for shareholder calls, so no more "we think it might be..." moments.',
    metric: '73%',
    metricLabel: 'faster decision-making',
  },
  {
    category: 'Work',
    title: 'Churn Prediction & Intervention Engine',
    desc: 'ML models forecasting customer churn and simulating responses to interventions (SMS, email, fee adjustments). Pushed internal decisioning coverage from 0% → 60%, cutting outsourced engagement volume by ~35%.',
    metric: '0 → 60%',
    metricLabel: 'decisioning coverage',
  },
  {
    category: 'Academic',
    title: 'Gravitational Microlensing Sim',
    desc: 'Academic project simulating gravitational microlensing events, the same physics that bends light around black holes. Built in Python with Jupyter. The astrophysics degree, paying dividends.',
    metric: 'The physics behind the live demo',
    metricLabel: '',
  },
  {
    category: 'Academic',
    title: 'DeepLabCut Pose Estimation',
    desc: 'Trained computer-vision models to track mouse joint positions in wet-lab video experiments. Kinematic data benchmarked against published neuroscience research. The weirdest and most interesting project I\'ve worked on.',
    metric: 'Neuroscience × Deep Learning',
    metricLabel: '',
  },
  {
    category: 'Personal',
    title: 'AniParty: Video Sync Extension',
    desc: 'Personal project: a browser extension that syncs video playback between computers. Built in JavaScript, because watching anime with friends across the country shouldn\'t require a scheduling meeting.',
    metric: 'Solving the important problems',
    metricLabel: '',
  },
];
---

<section id="projects" class="section">
  <div class="container">
    <div class="section-head-center">
      <span class="section-label reveal">Projects &amp; case studies</span>
      <h2 class="section-title reveal">What I've shipped</h2>
      <p class="section-sub reveal">
        Seven live demos you can play with right now, plus work projects (sanitized) and academic deep cuts.
      </p>
    </div>

    <div class="demo-grid">
      {demos.map((p) => (
        <a class="demo-card reveal interactive" href={p.href}>
          <figure class="demo-shot">
            <img src={p.img} alt={`Screenshot of ${p.title}`} width="1200" height="750" loading="lazy" />
          </figure>
          <div class="demo-body">
            <h3 class="demo-title">{p.title}</h3>
            <p class="demo-hook">{p.hook}</p>
            <span class="demo-cta">Try it live <span aria-hidden="true">→</span></span>
          </div>
        </a>
      ))}
    </div>

    <h3 class="more-label reveal">More work</h3>
    <div class="more-grid">
      {rest.map((p) => {
        const Tag = p.href ? 'a' : 'article';
        return (
          <Tag
            class:list={['more-item', 'reveal', { interactive: !!p.href }]}
            {...(p.href ? { href: p.href, target: '_blank', rel: 'noopener' } : {})}
          >
            <span class:list={['more-cat', `cat-${p.category.toLowerCase()}`]}>{p.category}</span>
            <h4 class="more-title">{p.title}{p.href && <span class="more-go" aria-hidden="true"> ↗</span>}</h4>
            <p class="more-desc">{p.desc}</p>
            <p class="more-metric">
              <strong>{p.metric}</strong>
              {p.metricLabel && <span> {p.metricLabel}</span>}
            </p>
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  #projects { border-top: 1px solid var(--border-soft); }
  .section-head-center { margin-bottom: clamp(56px, 7vw, 88px); }

  .demo-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 22px;
  }

  .demo-card {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-card);
    background: var(--surface);
    overflow: hidden;
    transition: background 0.3s, transform 0.35s var(--ease);
  }
  .demo-card:hover {
    background: var(--surface-hover);
    transform: translateY(-5px);
  }

  .demo-shot {
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #0b0813;
  }
  .demo-shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.001);
    transition: transform 0.6s var(--ease);
  }
  .demo-card:hover .demo-shot img { transform: scale(1.04); }

  .demo-body {
    display: flex;
    flex-direction: column;
    padding: 22px 26px 26px;
  }
  .demo-title {
    font-family: var(--font-display);
    font-size: clamp(19px, 1.8vw, 22px);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.015em;
    line-height: 1.25;
    margin-bottom: 4px;
    text-wrap: balance;
  }
  .demo-hook {
    font-size: 16px;
    color: var(--text-dim);
    font-weight: 300;
    margin-bottom: 16px;
  }
  .demo-cta {
    font-size: 15.5px;
    font-weight: 500;
    color: var(--purple-lt);
  }
  .demo-cta span { display: inline-block; transition: transform 0.25s var(--ease); }
  .demo-card:hover .demo-cta span { transform: translateX(3px); }

  /* Non-interactive work as a quiet editorial list */
  .more-label {
    font-family: var(--font-display);
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--text);
    margin: clamp(72px, 9vw, 120px) 0 8px;
  }
  .more-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(40px, 6vw, 80px);
  }
  .more-item {
    display: block;
    padding: 30px 0;
    border-top: 1px solid var(--border-soft);
  }
  /* Keep the top hairlines aligned across both columns */
  .more-item:nth-child(-n+2) { border-top: none; padding-top: 22px; }

  .more-cat {
    display: block;
    font-size: 13.5px;
    font-weight: 500;
    margin-bottom: 8px;
  }
  .cat-work     { color: var(--purple-lt); }
  .cat-academic { color: var(--lilac); }
  .cat-personal { color: var(--magenta); }

  .more-title {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    margin-bottom: 8px;
    transition: color 0.25s;
  }
  .more-go { color: var(--muted); font-weight: 400; }
  a.more-item:hover .more-title { color: var(--purple-lt); }

  .more-desc {
    font-size: 15.5px;
    color: var(--text-dim);
    font-weight: 300;
    line-height: 1.65;
    margin-bottom: 12px;
  }
  .more-metric { font-size: 14.5px; color: var(--muted); }
  .more-metric strong { color: var(--text); font-weight: 600; }

  @media (max-width: 1000px) {
    .demo-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 720px) {
    .demo-grid { grid-template-columns: 1fr; }
    .more-grid { grid-template-columns: 1fr; }
    .more-item:nth-child(2) { border-top: 1px solid var(--border-soft); padding-top: 30px; }
  }
</style>
