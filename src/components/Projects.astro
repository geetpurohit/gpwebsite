---
const projects = [
  {
    num: '01',
    featured: true,
    category: 'Personal',
    title: 'Credit-Default Scorecard (Live Demo)',
    desc: 'A loan-level credit-risk model you can actually play with. Enter an applicant and it scores their probability of default right in your browser, then shows exactly which factors drove the decision. Built with weight-of-evidence binning and logistic regression (how banks really build scorecards), benchmarked against XGBoost with SHAP, and trained on public LendingClub data.',
    tags: ['Python', 'scikit-learn', 'WOE / IV', 'XGBoost', 'SHAP'],
    metric: 'Try it live',
    metricLabel: 'interactive, in-browser',
    href: '/projects/credit-risk',
  },
  {
    num: '02',
    featured: true,
    category: 'Personal',
    title: 'Uplift Modeling: Who to Persuade (Live Demo)',
    desc: 'Predicting who converts is the easy question. This causal model answers the useful one: who converts only because you reached them. It estimates the incremental effect of a marketing email per customer using T-learner and X-learner meta-learners, validated with the Qini curve, then sorts everyone into Persuadables, Sure Things, Lost Causes, and Sleeping Dogs. Score a customer live, in your browser.',
    tags: ['Causal Inference', 'T / X-Learner', 'Qini', 'Python', 'scikit-learn'],
    metric: 'Try it live',
    metricLabel: 'interactive, in-browser',
    href: '/projects/uplift',
  },
  {
    num: '03',
    featured: true,
    category: 'Personal',
    title: 'Significance: A/B Test Designer (Live Demo)',
    desc: 'The experimentation toolkit behind a trustworthy A/B test. Power an experiment and size it before you launch, then analyze the results with a proper two-proportion z-test and confidence interval. Plus live demos of the two traps that quietly ruin most experiments: peeking (which inflates false positives past 25%) and skipping CUPED variance reduction. All computed in your browser.',
    tags: ['A/B Testing', 'Power Analysis', 'CUPED', 'Sequential Testing', 'Python'],
    metric: 'Try it live',
    metricLabel: 'interactive, in-browser',
    href: '/projects/experiment',
  },
  {
    num: '04',
    category: 'Work',
    title: 'Credit Risk Intelligence Platform',
    desc: 'Fullstack app that synthetically generates customer databases to monitor credit-policy changes and their downstream impact on bad-debt writeoff. Built end-to-end (data pipeline, ML models, and a Streamlit frontend) so finance teams can simulate policy scenarios without ever touching production data.',
    tags: ['Python', 'Streamlit', 'GCP', 'SQL', 'Synthetic Data'],
    metric: '$1.2B+',
    metricLabel: 'in bad debt monitored',
  },
  {
    num: '05',
    category: 'Work',
    title: 'XAI Gross-Adds Framework',
    desc: 'Explainable-AI framework isolating the real-time drivers of Verizon Gross Adds. Cut hypothesis-generation time by 73% for shareholder calls, so no more "we think it might be..." moments.',
    tags: ['XAI', 'Qlik', 'Python', 'ML'],
    metric: '73%',
    metricLabel: 'faster decision-making',
  },
  {
    num: '06',
    category: 'Academic',
    title: 'Gravitational Microlensing Sim',
    desc: 'Academic project simulating gravitational microlensing events, the same physics that bends light around black holes. Built in Python with Jupyter. The astrophysics degree, paying dividends.',
    tags: ['Python', 'Astrophysics', 'NumPy'],
    metric: 'github.com/geetpurohit',
    metricLabel: '',
    href: 'https://github.com/geetpurohit',
  },
  {
    num: '07',
    category: 'Work',
    title: 'Churn Prediction & Intervention Engine',
    desc: 'ML models forecasting customer churn and simulating responses to interventions (SMS, email, fee adjustments). Pushed internal decisioning coverage from 0% → 60%, cutting outsourced engagement volume by ~35%.',
    tags: ['ML', 'Python', 'Simulation', 'DataRobot'],
    metric: '0 → 60%',
    metricLabel: 'decisioning coverage',
  },
  {
    num: '08',
    category: 'Academic',
    title: 'DeepLabCut Pose Estimation',
    desc: 'Trained computer-vision models to track mouse joint positions in wet-lab video experiments. Kinematic data benchmarked against published neuroscience research. The weirdest and most interesting project I\'ve worked on.',
    tags: ['TensorFlow', 'CUDA', 'Computer Vision', 'R'],
    metric: 'Neuroscience × Deep Learning',
    metricLabel: '',
  },
  {
    num: '09',
    category: 'Personal',
    title: 'AniParty: Video Sync Extension',
    desc: 'Personal project: a browser extension that syncs video playback between computers. Built in JavaScript, because watching anime with friends across the country shouldn\'t require a scheduling meeting.',
    tags: ['JavaScript', 'Browser Extension', 'WebSockets'],
    metric: 'Solving the important problems',
    metricLabel: '',
  },
];
const featured = projects.filter((p) => p.featured);
const rest = projects.filter((p) => !p.featured);
---

<section id="projects" class="section">
  <div class="container">
    <span class="section-label reveal">Projects & Case Studies</span>
    <h2 class="section-title reveal">Things I've shipped</h2>
    <p class="section-sub reveal">A mix of work projects (sanitized), academic deep cuts, and personal experiments.</p>

    <div class="grid grid-featured">
      {featured.map((p) => {
        const Tag = p.href ? 'a' : 'article';
        return (
          <Tag
            class:list={['card', 'reveal', 'interactive', { featured: p.featured }]}
            {...(p.href ? { href: p.href, ...(p.href.startsWith('/') ? {} : { target: '_blank', rel: 'noopener' }) } : {})}
          >
            <div class="card-head">
              <span class="card-num">{p.num} · Live demo</span>
              <span class:list={['card-cat', `cat-${p.category.toLowerCase()}`]}>{p.category}</span>
            </div>
            <span class="card-go" aria-hidden="true">→</span>
            <h3 class="card-title">{p.title}</h3>
            <p class="card-desc">{p.desc}</p>
            <div class="card-tags">
              {p.tags.map((t) => <span class="card-tag">{t}</span>)}
            </div>
            <div class="card-metric">
              <span class="metric-num">{p.metric}</span>
              {p.metricLabel && <span class="metric-label">{p.metricLabel}</span>}
            </div>
          </Tag>
        );
      })}
    </div>

    <span class="grid-label reveal">More projects</span>
    <div class="grid grid-rest">
      {rest.map((p) => {
        const Tag = p.href ? 'a' : 'article';
        return (
          <Tag
            class:list={['card', 'reveal', 'interactive']}
            {...(p.href ? { href: p.href, ...(p.href.startsWith('/') ? {} : { target: '_blank', rel: 'noopener' }) } : {})}
          >
            <div class="card-head">
              <span class="card-num">{p.num}</span>
              <span class:list={['card-cat', `cat-${p.category.toLowerCase()}`]}>{p.category}</span>
            </div>
            <span class="card-go" aria-hidden="true">→</span>
            <h3 class="card-title">{p.title}</h3>
            <p class="card-desc">{p.desc}</p>
            <div class="card-tags">
              {p.tags.map((t) => <span class="card-tag">{t}</span>)}
            </div>
            <div class="card-metric">
              <span class="metric-num">{p.metric}</span>
              {p.metricLabel && <span class="metric-label">{p.metricLabel}</span>}
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  #projects { border-top: 1px solid var(--border-soft); }
  .section-sub { margin-bottom: clamp(48px, 6vw, 72px); }

  .grid {
    display: grid;
    gap: 18px;
  }
  .grid-featured { grid-template-columns: repeat(3, 1fr); }
  .grid-rest { grid-template-columns: repeat(3, 1fr); }

  .grid-label {
    display: block;
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin: clamp(34px, 5vw, 52px) 0 18px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--border-soft);
  }
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: 30px;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: linear-gradient(165deg, rgba(255,255,255,0.025), rgba(168,85,247,0.012));
    overflow: hidden;
    transition: border-color 0.3s, transform 0.3s, background 0.3s;
  }
  .card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 1px;
    background: var(--grad-line);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .card:hover {
    border-color: rgba(168,85,247,0.4);
    transform: translateY(-5px);
    background: linear-gradient(165deg, rgba(168,85,247,0.08), rgba(124,58,237,0.03));
  }
  .card:hover::before { opacity: 1; }

  .card.featured {
    padding: clamp(26px, 2.4vw, 32px);
    background: linear-gradient(140deg, rgba(168,85,247,0.10), rgba(124,58,237,0.04));
    border-color: rgba(168,85,247,0.28);
  }
  .card.featured .card-title { font-size: clamp(19px, 2vw, 23px); }
  .card.featured .card-desc { font-size: 15px; }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 14px;
  }
  .card-num {
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: 0.18em;
    color: var(--muted);
  }
  .card-cat {
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid currentColor;
    opacity: 0.9;
  }
  .cat-work     { color: var(--purple-lt); }
  .cat-academic { color: var(--lilac); }
  .cat-personal { color: var(--magenta); }

  /* Hover affordance */
  .card-go {
    position: absolute;
    top: 26px; right: 28px;
    font-size: 20px;
    line-height: 1;
    color: var(--purple-lt);
    opacity: 0;
    transform: translate(-6px, 6px);
    transition: opacity 0.3s, transform 0.3s var(--ease);
    pointer-events: none;
  }
  .card:hover .card-go { opacity: 1; transform: translate(0, 0); }

  .card-title {
    font-family: var(--font-display);
    font-size: 21px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
    line-height: 1.22;
    margin-bottom: 11px;
  }
  .card-desc {
    font-size: 15.5px;
    color: var(--text-dim);
    font-weight: 300;
    line-height: 1.72;
    margin-bottom: 18px;
  }
  .card-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; margin-top: auto; }
  .card-tag {
    font-size: 11.5px;
    padding: 4px 11px;
    border-radius: 6px;
    background: rgba(168,85,247,0.08);
    color: var(--lilac);
    border: 1px solid rgba(168,85,247,0.16);
  }

  /* Impact metric, promoted to a hero figure */
  .card-metric {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .metric-num {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.2vw, 26px);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    background: var(--grad-text);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }
  .metric-label {
    font-size: 12.5px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .card.featured .metric-num { font-size: clamp(26px, 3.4vw, 38px); }

  @media (max-width: 920px) {
    .grid-rest { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 820px) {
    .grid-featured { grid-template-columns: 1fr; }
  }
  @media (max-width: 600px) {
    .grid-rest { grid-template-columns: 1fr; }
  }
</style>
