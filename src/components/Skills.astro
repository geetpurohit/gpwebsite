---
const groups = [
  {
    title: 'Languages',
    items: [
      { name: 'Python', level: 96 },
      { name: 'SQL', level: 92 },
      { name: 'Java', level: 78 },
      { name: 'JavaScript', level: 70 },
      { name: 'R', level: 72 },
    ],
  },
  {
    title: 'ML / Data',
    items: [
      { name: 'Pandas / NumPy', level: 95 },
      { name: 'Scikit-learn', level: 90 },
      { name: 'DataRobot', level: 88 },
      { name: 'TensorFlow', level: 85 },
      { name: 'Apache Spark', level: 75 },
    ],
  },
  {
    title: 'Infrastructure',
    items: [
      { name: 'GCP / BigQuery', level: 88 },
      { name: 'PostgreSQL', level: 85 },
      { name: 'GitLab CI/CD', level: 82 },
      { name: 'Docker', level: 78 },
      { name: 'MongoDB', level: 70 },
    ],
  },
  {
    title: 'Visualization',
    items: [
      { name: 'Tableau', level: 90 },
      { name: 'Streamlit', level: 88 },
      { name: 'QlikSense', level: 85 },
      { name: 'Plotly', level: 82 },
      { name: 'D-Tale', level: 80 },
    ],
  },
];
---

<section id="skills" class="section">
  <div class="container">
    <span class="section-label reveal">Skills</span>
    <h2 class="section-title reveal">The toolkit</h2>
    <p class="section-sub reveal">Proficiency built by shipping things, not just finishing courses.</p>

    <div class="grid">
      {groups.map((g) => (
        <div class="group reveal">
          <h3 class="group-title">{g.title}</h3>
          <div class="list">
            {g.items.map((it) => (
              <div class="skill">
                <div class="skill-head">
                  <span class="skill-name">{it.name}</span>
                  <span class="skill-pct">{it.level}</span>
                </div>
                <div class="bar"><div class="fill" data-level={it.level}></div></div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  #skills { border-top: 1px solid var(--border-soft); }
  .section-sub { margin-bottom: clamp(48px, 6vw, 72px); }

  .grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
  }
  .group {
    padding: 28px 26px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(255,255,255,0.02);
    transition: border-color 0.3s;
  }
  .group:hover { border-color: rgba(168,85,247,0.3); }
  .group-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--purple-lt);
    margin-bottom: 20px;
  }
  .list { display: flex; flex-direction: column; gap: 16px; }
  .skill-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 7px; }
  .skill-name { font-size: 15px; color: var(--text-dim); font-weight: 300; }
  .skill-pct { font-family: var(--font-display); font-size: 11.5px; color: var(--muted); }
  .bar {
    height: 4px;
    background: rgba(255,255,255,0.06);
    border-radius: 999px;
    overflow: hidden;
  }
  .fill {
    height: 100%;
    width: 0;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--violet-deep), var(--purple), var(--lilac));
    transition: width 1.1s var(--ease);
  }

  @media (max-width: 920px) { .grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .grid { grid-template-columns: 1fr; } }
</style>

<script>
  const bars = new IntersectionObserver((entries) => {
    entries.forEach((e) => {
      if (e.isIntersecting) {
        e.target.querySelectorAll<HTMLElement>('.fill').forEach((f) => {
          f.style.width = (f.dataset.level || '0') + '%';
        });
        bars.unobserve(e.target);
      }
    });
  }, { threshold: 0.3 });
  document.querySelectorAll('#skills .group').forEach((g) => bars.observe(g));
</script>
