---
const chips = ['Machine Learning', 'XAI Frameworks', 'Causal Inference', 'Python & SQL', 'Georgia Tech MS'];
const stats = [
  { num: '$1.2B+', label: 'Bad-debt impact' },
  { num: '73%', label: 'Faster hypotheses' },
  { num: '4+ yrs', label: 'Data science experience' },
  { num: '2×', label: 'STEM degrees' },
];
---

<header id="hero">
  <div class="hero-inner container">
    <p class="tag"><span class="ping"></span>Data Scientist at Verizon&nbsp;·&nbsp;Open to opportunities</p>

    <h1 class="title">
      <span class="static-lines">
        <span class="line">Astrophysicist</span>
        <span class="line grad-text">Data Scientist</span>
        <span class="line">Storyteller</span>
      </span>
      <span class="type-line" aria-hidden="true" hidden>
        <span class="typed grad-text"></span><span class="caret"></span>
      </span>
    </h1>

    <p class="sub">
      I used to study black holes. Now I find them in datasets instead.
      <em>Both are equally mysterious, and both need a concerning amount of coffee.</em>
    </p>

    <div class="chips">
      {chips.map((c) => <span class="chip">{c}</span>)}
    </div>

    <div class="ctas">
      <a href="#projects" class="btn btn-primary">See my work</a>
      <a href="#contact" class="btn-quiet">Get in touch <span aria-hidden="true">→</span></a>
    </div>

    <dl class="stats">
      {stats.map((s) => (
        <div class="stat">
          <dt class="stat-num">{s.num}</dt>
          <dd class="stat-label">{s.label}</dd>
        </div>
      ))}
    </dl>
  </div>

  <a href="#about" class="scroll-hint" aria-label="Scroll to content">
    <span>Scroll</span>
    <span class="scroll-line"></span>
  </a>
</header>

<style>
  #hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: clamp(110px, 16vh, 170px) var(--pad-x) clamp(90px, 12vh, 130px);
    overflow: hidden;
    z-index: 2;
  }
  .hero-inner { position: relative; z-index: 2; max-width: 820px; }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 14.5px;
    font-weight: 500;
    letter-spacing: 0.01em;
    color: var(--text-dim);
    margin-bottom: 28px;
    opacity: 0;
    animation: fadeUp 0.8s var(--ease) forwards 0.15s;
  }
  .ping {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--purple);
    box-shadow: 0 0 0 0 rgba(168,85,247,0.6);
    animation: ping 2.2s var(--ease) infinite;
  }
  @keyframes ping {
    0%   { box-shadow: 0 0 0 0 rgba(168,85,247,0.6); }
    70%  { box-shadow: 0 0 0 10px rgba(168,85,247,0); }
    100% { box-shadow: 0 0 0 0 rgba(168,85,247,0); }
  }

  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(46px, 9vw, 112px);
    line-height: 1.0;
    letter-spacing: -0.03em;
    margin-bottom: 28px;
  }
  .title .line { display: block; opacity: 0; animation: fadeUp 0.85s var(--ease) forwards; }
  .static-lines .line:nth-child(1) { animation-delay: 0.28s; }
  .static-lines .line:nth-child(2) { animation-delay: 0.40s; }
  .static-lines .line:nth-child(3) { animation-delay: 0.52s; }

  .type-line {
    display: block;
    min-height: 1.05em;
    opacity: 0;
    animation: fadeUp 0.85s var(--ease) forwards 0.28s;
  }
  .type-line[hidden] { display: none; }
  .caret {
    display: inline-block;
    width: 0.06em;
    margin-left: 0.04em;
    background: var(--purple-lt);
    transform: translateY(0.12em);
    align-self: stretch;
    animation: caretBlink 1s steps(1) infinite;
  }
  .typed:empty + .caret,
  .typed + .caret { height: 0.92em; }
  @keyframes caretBlink {
    0%, 49% { opacity: 1; }
    50%, 100% { opacity: 0; }
  }

  .sub {
    font-size: clamp(18px, 1.6vw, 22px);
    color: var(--text-dim);
    font-weight: 300;
    line-height: 1.6;
    max-width: 540px;
    margin-bottom: 26px;
    opacity: 0;
    animation: fadeUp 0.85s var(--ease) forwards 0.66s;
  }
  .sub em { color: var(--muted); font-style: italic; }

  /* Quiet metadata line instead of a row of bordered chips */
  .chips {
    display: flex; flex-wrap: wrap; align-items: center;
    column-gap: 10px; row-gap: 6px;
    margin-bottom: 38px;
    opacity: 0;
    animation: fadeUp 0.85s var(--ease) forwards 0.78s;
  }
  .chip {
    font-size: 14.5px;
    color: var(--muted);
  }
  .chip:not(:last-child)::after {
    content: '·';
    margin-left: 10px;
    color: rgba(148,140,173,0.55);
  }

  .ctas {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: clamp(18px, 3vw, 28px);
    margin-bottom: 60px;
    opacity: 0;
    animation: fadeUp 0.85s var(--ease) forwards 0.9s;
  }
  .btn {
    padding: 14px 30px;
    border-radius: var(--radius-pill);
    font-size: 15px;
    font-weight: 500;
    letter-spacing: 0.01em;
    transition: filter 0.25s, transform 0.25s var(--ease);
  }
  .btn-primary {
    background: var(--purple);
    color: #fff;
  }
  .btn-primary:hover { filter: brightness(1.12); transform: translateY(-1px); }
  .btn-quiet {
    font-size: 15px;
    font-weight: 500;
    color: var(--purple-lt);
    transition: color 0.25s;
  }
  .btn-quiet span { display: inline-block; transition: transform 0.25s var(--ease); }
  .btn-quiet:hover { color: var(--lilac); }
  .btn-quiet:hover span { transform: translateX(3px); }

  .stats {
    display: flex;
    flex-wrap: wrap;
    gap: clamp(28px, 5vw, 64px);
    opacity: 0;
    animation: fadeUp 0.85s var(--ease) forwards 1.02s;
  }
  .stat { display: flex; flex-direction: column; gap: 4px; }
  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(24px, 2.8vw, 34px);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text);
    font-variant-numeric: tabular-nums; /* steady width while counting up */
  }
  .stat-label {
    font-size: 13.5px;
    color: var(--muted);
  }

  .scroll-hint {
    position: absolute;
    bottom: 30px; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    opacity: 0;
    animation: fadeUp 0.9s var(--ease) forwards 1.3s;
  }
  .scroll-hint span:first-child {
    font-family: var(--font-display);
    font-size: 10px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--muted);
  }
  .scroll-line {
    width: 1px; height: 42px;
    background: linear-gradient(var(--purple), transparent);
    animation: scrollPulse 2s var(--ease) infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.35; transform: scaleY(0.7); transform-origin: top; }
    50%      { opacity: 1;    transform: scaleY(1); }
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(22px); }
    to   { opacity: 1; transform: none; }
  }

  /* No room for the hint on small screens or short viewports — it would
     crowd the stats row. */
  @media (max-width: 820px), (max-height: 760px) {
    .scroll-hint { display: none; }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    || document.documentElement.classList.contains('no-motion');
  const staticLines = document.querySelector('.static-lines') as HTMLElement | null;
  const typeLine = document.querySelector('.type-line') as HTMLElement | null;
  const typedEl = document.querySelector('.type-line .typed') as HTMLElement | null;

  if (!reduce && staticLines && typeLine && typedEl) {
    staticLines.hidden = true;
    typeLine.hidden = false;

    const words = ['Astrophysicist', 'Data Scientist', 'Storyteller'];
    let wi = 0, ci = 0, deleting = false;

    const tick = () => {
      const word = words[wi];
      ci += deleting ? -1 : 1;
      typedEl.textContent = word.slice(0, ci);

      if (!deleting && ci === word.length) {
        deleting = true;
        setTimeout(tick, 1500);
      } else if (deleting && ci === 0) {
        deleting = false;
        wi = (wi + 1) % words.length;
        setTimeout(tick, 450);
      } else {
        setTimeout(tick, deleting ? 45 : 85 + Math.random() * 55);
      }
    };

    setTimeout(tick, 1100);
  }

  // Stats count up once the hero has had a moment to land. Each figure climbs
  // through its real units on the way: dollars sweep the magnitudes
  // ($100 → $1K → $1M → $1.2B), experience runs through months before years.
  const statEls = Array.from(document.querySelectorAll<HTMLElement>('.stat-num'));
  if (!reduce && statEls.length) {
    const fmtMoney = (p: number) => {
      if (p <= 0) return '$0';
      if (p >= 1) return '$1.2B+';
      const v = Math.pow(10, 2 + 7.079 * p); // log-space: $100 → $1.2B
      if (v >= 1e9) return '$' + (v / 1e9).toFixed(1) + 'B';
      if (v >= 1e6) return '$' + Math.round(v / 1e6) + 'M';
      if (v >= 1e3) return '$' + Math.round(v / 1e3) + 'K';
      return '$' + Math.round(v);
    };
    const fmtYears = (p: number) => {
      if (p >= 1) return '4+ yrs';
      const months = Math.floor(48 * p);
      if (months < 12) return months + ' mo';
      const y = Math.floor(months / 12), m = months % 12;
      return m ? `${y} yr ${m} mo` : `${y} yr`;
    };
    const fmtPct = (p: number) => (p >= 1 ? '73%' : Math.round(73 * p) + '%');
    const fmtX = (p: number) => (p >= 1 ? '2×' : (2 * p).toFixed(1) + '×');

    const formatters: Record<string, (p: number) => string> = {
      '$1.2B+': fmtMoney,
      '73%': fmtPct,
      '4+ yrs': fmtYears,
      '2×': fmtX,
    };
    const parsed = statEls
      .map((el) => {
        const fmt = formatters[(el.textContent ?? '').trim()];
        return fmt ? { el, fmt } : null;
      })
      .filter((s): s is { el: HTMLElement; fmt: (p: number) => string } => s !== null);

    const io = new IntersectionObserver((entries) => {
      if (!entries.some((e) => e.isIntersecting)) return;
      io.disconnect();
      // Give the reader a beat to take in the hero first, then count.
      const t0 = performance.now() + 2000;
      const dur = 2400;
      parsed.forEach((s) => { s.el.textContent = s.fmt(0); });
      const step = (now: number) => {
        const p = Math.min(Math.max((now - t0) / dur, 0), 1);
        const ease = 1 - Math.pow(1 - p, 3);
        parsed.forEach((s) => { s.el.textContent = s.fmt(ease); });
        if (p < 1) requestAnimationFrame(step);
      };
      requestAnimationFrame(step);
    }, { threshold: 0.5 });
    io.observe(statEls[0]);
  }

  // As you scroll away, the hero settles back: a slow drift and fade,
  // so the transition into the page feels continuous. The scroll hint fades
  // first — it has done its job, and the drifting stats would collide with it.
  const heroInner = document.querySelector<HTMLElement>('.hero-inner');
  const scrollHint = document.querySelector<HTMLElement>('.scroll-hint');
  if (!reduce && heroInner) {
    let ticking = false;
    const update = () => {
      ticking = false;
      const y = window.scrollY;
      const range = window.innerHeight * 0.72;
      const f = Math.min(y / range, 1);
      heroInner.style.opacity = String(1 - f * 0.95);
      heroInner.style.transform = `translateY(${y * 0.14}px)`;
      if (scrollHint) {
        // Kill the entrance animation first: its fill-mode would otherwise
        // override the inline opacity we set here.
        if (y > 0) scrollHint.style.animation = 'none';
        const h = Math.max(0, 1 - y / 120);
        scrollHint.style.opacity = String(h);
        scrollHint.style.pointerEvents = h < 0.1 ? 'none' : '';
      }
    };
    window.addEventListener('scroll', () => {
      if (!ticking) { ticking = true; requestAnimationFrame(update); }
    }, { passive: true });
  }
</script>
