---
import Base from '../../layouts/Base.astro';

const title = 'Uplift Modeling: Who to Persuade | Geet Purohit';
const description =
  'A causal uplift model (T-learner and X-learner meta-learners, evaluated with the Qini curve) that predicts the incremental effect of a marketing email, then sorts every customer into Persuadables, Sure Things, Lost Causes, and Sleeping Dogs. Live in-browser demo.';
---

<Base title={title} description={description}>
  <main class="up">
    <div class="up-container">
      <a class="back" href="/#projects">← geetpurohit.com</a>

      <!-- ===== Header ===== -->
      <header class="up-head reveal">
        <span class="section-label">Project · Causal Inference</span>
        <h1 class="up-title">Who Should You <span class="grad-text">Persuade?</span></h1>
        <p class="up-lead">
          Most models predict <em>who will convert</em>. That is the wrong question for a
          marketing budget. What you actually want is <strong>who converts only because you
          reached them</strong>, the incremental lift, not the raw likelihood. This is an
          <strong>uplift model</strong>: it estimates the causal effect of sending an email on
          each customer, using <strong>T-learner and X-learner meta-learners</strong> validated
          with the <strong>Qini curve</strong>. It runs on a real randomized experiment, the
          <a href="https://blog.minethatdata.com/2008/03/minethatdata-e-mail-analytics-and-data.html" target="_blank" rel="noopener">Hillstrom email dataset</a>
          of 64,000 customers.
        </p>
        <div class="tags">
          <span class="tag">Python</span>
          <span class="tag">Causal Inference</span>
          <span class="tag">T-Learner</span>
          <span class="tag">X-Learner</span>
          <span class="tag">Qini / AUUC</span>
          <span class="tag">scikit-learn</span>
        </div>
      </header>

      <div id="placeholderBanner" class="banner" hidden>
        ⚠️ Demo is running on <strong>placeholder coefficients</strong>. Run
        <code>causal-uplift/train.py</code> to populate it with values learned from real data.
      </div>

      <!-- ===== Interactive persuadability map ===== -->
      <section class="demo reveal">
        <div class="map-layout">
          <div class="map-col">
            <h2 class="block-h">Map a customer</h2>
            <p class="block-sub">
              Adjust the customer and watch them <em>move</em> across the persuadability map.
              Left to right is how likely they are to visit anyway; bottom to top is the causal
              lift from emailing. The corner they land in is the decision.
            </p>
            <div class="pmap">
              <div class="pmap-plot" id="pmapPlot" data-q="lost">
                <div class="quad q-persuadable" data-q="persuadable"><b>Persuadables</b><span>email tips them over</span></div>
                <div class="quad q-sure" data-q="sure"><b>Sure Things</b><span>convert anyway</span></div>
                <div class="quad q-lost" data-q="lost"><b>Lost Causes</b><span>won't convert either way</span></div>
                <div class="quad q-sleeping" data-q="sleeping"><b>Sleeping Dogs</b><span>emailing backfires</span></div>
                <div class="axis-v"></div>
                <div class="axis-h"></div>
                <div class="dot" id="dot"><span class="dot-ring"></span></div>
              </div>
              <div class="axis-cap axis-x">baseline visit likelihood, without email &nbsp;&rarr;</div>
              <div class="axis-cap axis-y">causal uplift from emailing &nbsp;&uarr;</div>
            </div>
          </div>

          <div class="ctrl-col">
            <div class="readout" id="readoutCard" data-q="lost">
              <div class="ro-quad" id="quad">-</div>
              <div class="ro-action" id="action">-</div>
              <div class="ro-nums">
                <div class="ro-col"><div id="pCtrl" class="ro-num">-</div><div class="ro-cap">without email</div></div>
                <div class="ro-col"><div id="pTreat" class="ro-num">-</div><div class="ro-cap">with email</div></div>
                <div class="ro-col"><div id="pUplift" class="ro-num up">-</div><div class="ro-cap">uplift (causal)</div></div>
              </div>
            </div>
            <form id="upForm" class="fields" autocomplete="off"><!-- inputs injected by JS --></form>
          </div>
        </div>
      </section>

      <!-- ===== Results ===== -->
      <section class="results reveal">
        <h2 class="block-h">Does the model actually rank uplift?</h2>
        <div class="tiles">
          <div class="tile"><div id="mAte" class="tile-num">-</div><div class="tile-cap">Average lift <span>email vs no email</span></div></div>
          <div class="tile"><div id="mQt" class="tile-num">-</div><div class="tile-cap">Qini <span>T-learner</span></div></div>
          <div class="tile"><div id="mQx" class="tile-num">-</div><div class="tile-cap">Qini <span>X-learner challenger</span></div></div>
          <div class="tile"><div id="mN" class="tile-num">-</div><div class="tile-cap">Customers <span>randomized trial</span></div></div>
        </div>

        <div class="charts">
          <figure class="chart"><div class="svg-wrap"><svg id="svgQini" class="svg-chart" viewBox="0 0 620 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Qini curve"></svg></div><figcaption>Qini curve: incremental visits captured vs. fraction targeted. Above the diagonal means the model beats targeting at random.</figcaption></figure>
          <figure class="chart"><div class="svg-wrap"><svg id="svgDeciles" class="svg-chart" viewBox="0 0 620 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Lift by decile"></svg></div><figcaption>Actual visit lift by predicted-uplift decile. Monotonic and rising means the ranking is real, not noise.</figcaption></figure>
          <figure class="chart"><div class="svg-wrap"><svg id="svgDist" class="svg-chart" viewBox="0 0 620 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Uplift distribution"></svg></div><figcaption>Predicted uplift across all customers. Some are genuinely persuadable, some barely move, a few are negative.</figcaption></figure>
          <figure class="chart"><div class="svg-wrap"><svg id="svgAte" class="svg-chart" viewBox="0 0 620 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Treated vs control visit rate"></svg></div><figcaption>The raw experiment: emailing lifts the average visit rate. Uplift modeling turns that average into a per-customer decision.</figcaption></figure>
        </div>
      </section>

      <!-- ===== Method ===== -->
      <section class="method reveal">
        <h2 class="block-h">How it works</h2>
        <ol class="steps">
          <li><strong>A real experiment.</strong> Customers were randomly assigned to receive an email or not, so a simple difference in visit rates is already an unbiased causal effect. Randomization is what makes the uplift identifiable.</li>
          <li><strong>T-learner.</strong> Two models are fit: one on the treated group, one on the control group. The predicted uplift for a customer is the difference between what each model says, P(visit | emailed) minus P(visit | not emailed).</li>
          <li><strong>X-learner.</strong> A stronger challenger that imputes each customer's individual treatment effect and models it directly, which helps when the treated and control groups are unbalanced. Reported alongside as a Qini benchmark.</li>
          <li><strong>Qini curve.</strong> Accuracy is meaningless here (you never see both outcomes for one person). Instead the model is judged on whether ranking customers by predicted uplift captures more incremental visits per email than random, which is exactly what a Qini curve measures.</li>
          <li><strong>Decision.</strong> Each customer lands in one of four quadrants. The budget goes to Persuadables, and Sleeping Dogs get left alone.</li>
        </ol>
        <div class="repo">
          <a class="btn" href="https://github.com/geetpurohit" target="_blank" rel="noopener">View the code on GitHub →</a>
        </div>
      </section>
    </div>
  </main>

  <script>
    type Feature = {
      key: string; label: string; type: 'numeric' | 'binary' | 'categorical';
      input: { min?: number; max?: number; step?: number; default: number | string };
      categories?: { value: string; label: string }[];
    };

    const $ = (id: string) => document.getElementById(id)!;
    const sig = (z: number) => 1 / (1 + Math.exp(-z));

    // Smoothly tween a number readout toward its target (adds life on every change).
    function animateNum(el: HTMLElement, to: number, fmt: (x: number) => string) {
      const a = el as any;
      const from = typeof a._v === 'number' ? a._v : to;
      a._v = to;
      if (a._raf) cancelAnimationFrame(a._raf);
      const start = performance.now(), dur = 420;
      const step = (now: number) => {
        const t = Math.min(1, (now - start) / dur);
        const e = 1 - Math.pow(1 - t, 3);
        el.textContent = fmt(from + (to - from) * e);
        if (t < 1) a._raf = requestAnimationFrame(step);
      };
      a._raf = requestAnimationFrame(step);
    }

    // ---- animated SVG charts ----
    const SVGNS = 'http://www.w3.org/2000/svg';
    function E(tag: string, attrs: Record<string, any>, parent?: Element): SVGElement {
      const e = document.createElementNS(SVGNS, tag);
      for (const k in attrs) e.setAttribute(k, String(attrs[k]));
      if (parent) parent.appendChild(e);
      return e as SVGElement;
    }
    const GEO = { W: 620, H: 400, l: 54, r: 20, t: 26, b: 46 };
    const lerp = (v: number, d0: number, d1: number, r0: number, r1: number) =>
      r0 + (d1 === d0 ? 0 : (v - d0) / (d1 - d0)) * (r1 - r0);

    function frame(svg: SVGElement, xlabel: string, ylabel: string) {
      const { l, r, t, b, W, H } = GEO;
      E('line', { x1: l, y1: H - b, x2: W - r, y2: H - b, stroke: '#2a2440', 'stroke-width': 1 }, svg);
      E('line', { x1: l, y1: t, x2: l, y2: H - b, stroke: '#2a2440', 'stroke-width': 1 }, svg);
      if (xlabel) { const tx = E('text', { x: (l + W - r) / 2, y: H - 8, 'text-anchor': 'middle', class: 'ax-lbl' }, svg); tx.textContent = xlabel; }
      if (ylabel) { const ty = E('text', { x: 15, y: (t + H - b) / 2, 'text-anchor': 'middle', transform: `rotate(-90 15 ${(t + H - b) / 2})`, class: 'ax-lbl' }, svg); ty.textContent = ylabel; }
    }
    function yGrid(svg: SVGElement, ymin: number, ymax: number, fmt: (v: number) => string, n = 4) {
      const { l, r, t, b, W, H } = GEO;
      for (let i = 0; i <= n; i++) {
        const v = ymin + (ymax - ymin) * i / n;
        const yy = lerp(v, ymin, ymax, H - b, t);
        E('line', { x1: l, y1: yy, x2: W - r, y2: yy, stroke: '#181327', 'stroke-width': 1 }, svg);
        const tk = E('text', { x: l - 8, y: yy + 3.5, 'text-anchor': 'end', class: 'ax-tick' }, svg); tk.textContent = fmt(v);
      }
    }
    function bar(svg: SVGElement, x: number, y: number, w: number, h: number, fill: string, delay: number) {
      const rc = E('rect', { x, y, width: w, height: Math.max(0, h), rx: 2, fill, class: 'bar' }, svg);
      (rc as unknown as HTMLElement).style.transition = `transform .7s cubic-bezier(.2,.7,.3,1) ${delay}s`;
    }
    function legend(svg: SVGElement, items: Array<[string, string]>) {
      const { l, t } = GEO;
      let x = l + 4;
      for (const [label, color] of items) {
        const g = E('g', {}, svg);
        E('rect', { x, y: t + 1, width: 14, height: 3, rx: 1.5, fill: color }, g);
        const tx = E('text', { x: x + 19, y: t + 7, class: 'leg-txt' }, g); tx.textContent = label;
        x += 19 + label.length * 6.4 + 16;
      }
    }
    const plays: Array<{ el: SVGElement; play: () => void; done: boolean }> = [];
    const onPlay = (svg: SVGElement, play: () => void) => plays.push({ el: svg, play, done: false });

    function renderCharts(c: any) {
      const { l, r, t, b, W, H } = GEO;

      // 1) Qini — lines drawn left to right via an expanding clip
      (() => {
        const svg = $('svgQini') as unknown as SVGElement;
        const { fr, t: T, x: Xr, rand: R } = c.qini;
        const ymax = (Math.max(...T, ...Xr, ...R) || 1) * 1.06;
        yGrid(svg, 0, ymax, (v) => String(Math.round(v)));
        frame(svg, 'fraction of customers targeted', 'incremental visits');
        const X = (v: number) => lerp(v, 0, 1, l, W - r);
        const Y = (v: number) => lerp(v, 0, ymax, H - b, t);
        const d = (arr: number[]) => arr.map((v: number, i: number) => (i ? 'L' : 'M') + X(fr[i]).toFixed(1) + ' ' + Y(v).toFixed(1)).join(' ');
        const cp = E('clipPath', { id: 'clipQini' }, svg);
        const rect = E('rect', { x: l, y: t - 6, width: 0, height: H - b - t + 12 }, cp);
        const g = E('g', { 'clip-path': 'url(#clipQini)' }, svg);
        E('path', { d: d(R), fill: 'none', stroke: '#4b4368', 'stroke-width': 1.4, 'stroke-dasharray': '2 4' }, g);
        E('path', { d: d(Xr), fill: 'none', stroke: '#f0abfc', 'stroke-width': 1.8, 'stroke-dasharray': '7 5' }, g);
        E('path', { d: d(T), fill: 'none', stroke: '#d946ef', 'stroke-width': 2.6 }, g);
        legend(svg, [['T-learner', '#d946ef'], ['X-learner', '#f0abfc'], ['random', '#4b4368']]);
        onPlay(svg, () => {
          const full = W - r - l, dur = 1300, s = performance.now();
          const step = (now: number) => { const p = Math.min(1, (now - s) / dur); rect.setAttribute('width', String(full * (1 - Math.pow(1 - p, 3)))); if (p < 1) requestAnimationFrame(step); };
          requestAnimationFrame(step);
        });
      })();

      // 2) Deciles — bars grow up, with the average-lift line
      (() => {
        const svg = $('svgDeciles') as unknown as SVGElement;
        const lift = c.deciles.lift as number[], ate = c.deciles.ate as number;
        const ymax = Math.max(...lift, ate) * 1.14;
        yGrid(svg, 0, ymax, (v) => v.toFixed(0) + '%');
        frame(svg, 'predicted-uplift decile (least to most)', 'actual visit lift (pp)');
        const bw = (W - r - l) / lift.length;
        const Y = (v: number) => lerp(v, 0, ymax, H - b, t);
        lift.forEach((v, i) => bar(svg, l + i * bw + bw * 0.16, Y(v), bw * 0.68, (H - b) - Y(v), v >= ate ? '#d946ef' : '#8b5cf6', i * 0.05));
        const ly = Y(ate);
        const avg = E('line', { x1: l, y1: ly, x2: W - r, y2: ly, stroke: '#34d399', 'stroke-width': 1.4, 'stroke-dasharray': '6 4', class: 'fade' }, svg);
        const lt = E('text', { x: W - r, y: ly - 6, 'text-anchor': 'end', class: 'leg-txt fade', fill: '#34d399' }, svg); lt.textContent = `avg +${ate}%`;
        onPlay(svg, () => svg.classList.add('play'));
      })();

      // 3) Distribution — histogram bars grow, with the zero-uplift line
      (() => {
        const svg = $('svgDist') as unknown as SVGElement;
        const counts = c.distribution.counts as number[], edges = c.distribution.edges as number[];
        const ymax = Math.max(...counts) * 1.08, xmin = edges[0], xmax = edges[edges.length - 1];
        yGrid(svg, 0, ymax, (v) => v >= 1000 ? (v / 1000).toFixed(0) + 'k' : String(Math.round(v)));
        frame(svg, 'predicted uplift (pp)', 'customers');
        const X = (v: number) => lerp(v, xmin, xmax, l, W - r);
        const Y = (v: number) => lerp(v, 0, ymax, H - b, t);
        counts.forEach((cnt, i) => bar(svg, X(edges[i]) + 0.5, Y(cnt), Math.max(1, X(edges[i + 1]) - X(edges[i]) - 1), (H - b) - Y(cnt), '#8b5cf6', i * 0.02));
        const zx = X(0);
        E('line', { x1: zx, y1: t, x2: zx, y2: H - b, stroke: '#fb7185', 'stroke-width': 1.4, 'stroke-dasharray': '5 4' }, svg);
        onPlay(svg, () => svg.classList.add('play'));
      })();

      // 4) ATE — two bars grow up, with value labels
      (() => {
        const svg = $('svgAte') as unknown as SVGElement;
        const control = c.ate.control as number, treated = c.ate.treated as number;
        const ymax = treated * 1.2;
        yGrid(svg, 0, ymax, (v) => v.toFixed(0) + '%');
        frame(svg, '', 'visit rate');
        const cats: Array<[string, number, string]> = [['No email', control, '#6b6688'], ['Email', treated, '#d946ef']];
        const bw = (W - r - l) / 2;
        const Y = (v: number) => lerp(v, 0, ymax, H - b, t);
        cats.forEach(([name, val, fill], i) => {
          const x = l + i * bw + bw * 0.24, yy = Y(val);
          bar(svg, x, yy, bw * 0.52, (H - b) - yy, fill, i * 0.12);
          const vt = E('text', { x: x + bw * 0.26, y: yy - 8, 'text-anchor': 'middle', class: 'val-txt fade' }, svg); vt.textContent = val + '%';
          const ct = E('text', { x: x + bw * 0.26, y: H - b + 18, 'text-anchor': 'middle', class: 'ax-tick' }, svg); ct.textContent = name;
        });
        onPlay(svg, () => svg.classList.add('play'));
      })();

      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (!en.isIntersecting) return;
          const rec = plays.find((o) => o.el === en.target && !o.done);
          if (rec) { rec.done = true; rec.play(); }
          io.unobserve(en.target);
        });
      }, { threshold: 0.3 });
      plays.forEach((o) => io.observe(o.el));
    }

    async function main() {
      let data: any;
      try {
        const res = await fetch('/uplift/uplift.json', { cache: 'no-cache' });
        data = await res.json();
      } catch {
        return;
      }

      const feats: Feature[] = data.features;
      const enc = data.encoding;
      const thr = data.meta.response_threshold as number;

      if (typeof data.meta?.generated === 'string' && data.meta.generated.startsWith('placeholder')) {
        $('placeholderBanner').hidden = false;
      }

      const pct = (x: number) => (x * 100).toFixed(1) + '%';
      $('mAte').textContent = '+' + pct(data.meta.ate);
      $('mQt').textContent = data.metrics?.t_learner?.qini?.toFixed(3) ?? '-';
      $('mQx').textContent = data.metrics?.x_learner?.qini?.toFixed(3) ?? '-';
      $('mN').textContent = ((data.meta.n_train + data.meta.n_test) / 1000).toFixed(0) + 'k';

      if (data.charts) renderCharts(data.charts);

      // Build inputs
      const form = $('upForm');
      form.innerHTML = feats.map((f) => {
        if (f.type === 'numeric') {
          const i = f.input as any;
          return `<label class="field">
            <span class="field-top"><span>${f.label}</span><output id="out_${f.key}"></output></span>
            <input type="range" id="in_${f.key}" min="${i.min}" max="${i.max}" step="${i.step}" value="${i.default}" />
          </label>`;
        }
        if (f.type === 'binary') {
          return `<label class="field field-toggle">
            <input type="checkbox" id="in_${f.key}" />
            <span>${f.label}</span>
          </label>`;
        }
        const opts = (f.categories || []).map((c) => `<option value="${c.value}">${c.label}</option>`).join('');
        return `<label class="field">
          <span class="field-top"><span>${f.label}</span></span>
          <select id="in_${f.key}" class="select">${opts}</select>
        </label>`;
      }).join('');

      feats.forEach((f) => {
        const el = $('in_' + f.key) as HTMLInputElement;
        if (f.type === 'categorical') el.value = String(f.input.default);
        el.addEventListener('input', compute);
        el.addEventListener('change', compute);
      });

      // Build the model column vector from the raw inputs (mirrors train.py encode())
      function vector(): number[] {
        const val = (k: string) => $('in_' + k) as HTMLInputElement;
        const recency = parseFloat(val('recency').value);
        const history = parseFloat(val('history').value);
        const out = $('out_recency'); if (out) out.textContent = recency + ' mo';
        const outh = $('out_history'); if (outh) outh.textContent = '$' + Math.round(history).toLocaleString();
        const zip = val('zip_code').value;
        const chan = val('channel').value;
        return [
          (recency - enc.recency.mean) / enc.recency.std,
          (Math.log1p(history) - enc.history.mean) / enc.history.std,
          val('mens').checked ? 1 : 0,
          val('womens').checked ? 1 : 0,
          val('newbie').checked ? 1 : 0,
          zip === 'Urban' ? 1 : 0,
          zip === 'Rural' ? 1 : 0,
          chan === 'Web' ? 1 : 0,
          chan === 'Multichannel' ? 1 : 0,
        ];
      }

      const score = (m: any, v: number[]) => {
        let z = m.intercept;
        data.columns.forEach((c: string, i: number) => { z += m.coef[c] * v[i]; });
        return sig(z);
      };

      const QUAD: Record<string, { label: string; action: string }> = {
        persuadable: { label: 'Persuadable', action: 'Send the email. This visit happens only because you reached them.' },
        sure:        { label: 'Sure Thing', action: 'Skip it. They were going to visit anyway, so the email is wasted spend.' },
        lost:        { label: 'Lost Cause', action: 'Skip it. Unlikely to visit whether you email or not.' },
        sleeping:    { label: 'Sleeping Dog', action: 'Do not email. Reaching them actually lowers their chance of visiting.' },
      };

      function compute() {
        const v = vector();
        const pt = score(data.models.treat, v);
        const pc = score(data.models.control, v);
        const up = pt - pc;

        animateNum($('pCtrl'), pc, (x) => pct(x));
        animateNum($('pTreat'), pt, (x) => pct(x));
        const upEl = $('pUplift');
        animateNum(upEl, up, (x) => (x >= 0 ? '+' : '') + pct(x));
        upEl.className = 'ro-num up ' + (up < -0.002 ? 'neg' : up > 0.002 ? 'pos' : 'flat');

        // position the customer on the map: x = baseline vs threshold, y = uplift
        const cx = 50 + Math.max(-1, Math.min(1, (pc - thr) / 0.16)) * 42;
        const cy = 50 - Math.max(-1, Math.min(1, up / 0.12)) * 42;
        const dot = $('dot') as HTMLElement;
        dot.style.left = cx + '%';
        dot.style.top = cy + '%';

        // quadrant: high/low baseline (x) by positive/negative uplift (y)
        const q = up >= 0 ? (pc < thr ? 'persuadable' : 'sure') : (pc < thr ? 'lost' : 'sleeping');
        $('quad').textContent = QUAD[q].label;
        $('action').textContent = QUAD[q].action;
        ($('pmapPlot') as HTMLElement).dataset.q = q;
        ($('readoutCard') as HTMLElement).dataset.q = q;
        document.querySelectorAll<HTMLElement>('.quad').forEach((c) => {
          c.classList.toggle('active', c.dataset.q === q);
        });
      }

      compute();
    }

    main();
  </script>

  <style>
    .up {
      position: relative; z-index: 2; padding: clamp(28px, 6vw, 64px) var(--pad-x) 120px;
      /* Persuade theme: magenta / fuchsia causal-inference identity */
      --violet: #c026d3; --purple: #d946ef; --purple-lt: #e879f9; --lilac: #f0abfc; --magenta: #ec4899;
      --accent-rgb: 217,70,239;
      --grad-text: linear-gradient(120deg, #e879f9 0%, #d946ef 40%, #c026d3 75%, #f0abfc 100%);
      --grad-line: linear-gradient(90deg, transparent, #d946ef, transparent);
    }
    .up-container { width: 100%; max-width: 1080px; margin-inline: auto; }
    .back {
      display: inline-block; font-family: var(--font-display); font-size: 13px;
      color: var(--muted); margin-bottom: clamp(32px, 6vw, 56px); transition: color .25s;
    }
    .back:hover { color: var(--lilac); }

    .up-title {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(34px, 6vw, 68px); letter-spacing: -0.03em; line-height: 1.02; margin-bottom: 22px;
    }
    .up-lead { font-size: clamp(16.5px, 1.3vw, 19px); color: var(--text-dim); font-weight: 300; line-height: 1.8; max-width: 800px; }
    .up-lead strong { color: var(--text); font-weight: 500; }
