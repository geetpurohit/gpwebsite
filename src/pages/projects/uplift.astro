    /* Demo */
    .demo { margin-top: clamp(48px, 7vw, 76px); }
    .map-layout {
      display: grid; grid-template-columns: 1.1fr 0.9fr; gap: clamp(24px, 4vw, 44px);
      padding: clamp(22px, 3vw, 34px); border: 1px solid var(--border); border-radius: 20px;
      background: linear-gradient(165deg, rgba(255,255,255,0.022), rgba(var(--accent-rgb),0.02));
      align-items: start;
    }
    .map-col { min-width: 0; }
