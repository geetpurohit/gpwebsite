    /* persuadability map */
    .pmap { display: grid; grid-template-columns: 16px 1fr; grid-template-rows: 1fr 16px; gap: 6px; margin-top: 18px; }
    .pmap-plot {
      grid-column: 2; grid-row: 1; position: relative; aspect-ratio: 1 / 1; width: 100%;
      border: 1px solid var(--border); border-radius: 14px; overflow: hidden;
      display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr;
      background: rgba(255,255,255,0.015);
    }
    .quad { position: relative; padding: 12px 14px; display: flex; flex-direction: column; gap: 3px; transition: background .3s; }
    .quad b { font-family: var(--font-display); font-weight: 600; font-size: 12.5px; color: var(--text-dim); transition: color .3s; }
    .quad span { font-size: 10px; color: var(--muted); line-height: 1.25; }
    .q-persuadable { grid-area: 1 / 1; }
    .q-sure        { grid-area: 1 / 2; text-align: right; align-items: flex-end; }
    .q-lost        { grid-area: 2 / 1; justify-content: flex-end; }
    .q-sleeping    { grid-area: 2 / 2; justify-content: flex-end; text-align: right; align-items: flex-end; }
    .q-persuadable.active { background: rgba(52,211,153,0.12); } .q-persuadable.active b { color: #34d399; }
    .q-sure.active { background: rgba(var(--accent-rgb),0.12); } .q-sure.active b { color: var(--lilac); }
    .q-lost.active { background: rgba(148,140,173,0.12); } .q-lost.active b { color: var(--text); }
    .q-sleeping.active { background: rgba(244,63,94,0.12); } .q-sleeping.active b { color: #fb7185; }

    .axis-v { position: absolute; left: 50%; top: 0; bottom: 0; width: 1px; background: rgba(255,255,255,0.14); z-index: 2; }
    .axis-h { position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: rgba(255,255,255,0.14); z-index: 2; }

    .dot {
      position: absolute; left: 50%; top: 50%; width: 15px; height: 15px; z-index: 4; transform: translate(-50%, -50%);
      transition: left .55s cubic-bezier(.34,1.35,.5,1), top .55s cubic-bezier(.34,1.35,.5,1);
    }
    .dot::after {
      content: ''; position: absolute; inset: 0; border-radius: 50%;
      background: var(--purple-lt); border: 2px solid #fff; box-shadow: 0 0 12px 2px rgba(var(--accent-rgb), 0.7);
      transition: background .3s, box-shadow .3s;
    }
    .dot-ring { position: absolute; inset: -5px; border-radius: 50%; border: 2px solid var(--purple-lt); animation: dotpulse 1.8s ease-out infinite; }
    @keyframes dotpulse { 0% { transform: scale(.55); opacity: .6; } 100% { transform: scale(1.9); opacity: 0; } }
    .pmap-plot[data-q="persuadable"] .dot::after { background: #34d399; box-shadow: 0 0 12px 2px rgba(52,211,153,.7); }
    .pmap-plot[data-q="persuadable"] .dot-ring { border-color: #34d399; }
    .pmap-plot[data-q="sleeping"] .dot::after { background: #fb7185; box-shadow: 0 0 12px 2px rgba(244,63,94,.7); }
    .pmap-plot[data-q="sleeping"] .dot-ring { border-color: #fb7185; }

    .axis-cap { font-size: 10px; color: var(--muted); letter-spacing: .02em; }
    .axis-x { grid-column: 2; grid-row: 2; text-align: center; }
    .axis-y { grid-column: 1; grid-row: 1; writing-mode: vertical-rl; transform: rotate(180deg); display: flex; align-items: center; justify-content: center; }
    .fields { display: grid; grid-template-columns: 1fr 1fr; gap: 16px 22px; align-content: start; }
    .field { display: flex; flex-direction: column; gap: 8px; font-size: 13.5px; }
    .field-top { display: flex; justify-content: space-between; align-items: baseline; color: var(--text-dim); }
    .field-top output { font-family: var(--font-display); font-weight: 600; color: var(--lilac); font-size: 13px; }
    .field-toggle { flex-direction: row; align-items: center; gap: 10px; color: var(--text-dim); cursor: pointer; grid-column: span 2; }
    .field-toggle input { width: 16px; height: 16px; accent-color: var(--purple); cursor: pointer; }
    input[type=range] { -webkit-appearance: none; appearance: none; width: 100%; height: 4px; border-radius: 3px;
      background: linear-gradient(90deg, var(--violet), var(--purple)); outline: none; }
    input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; width: 16px; height: 16px; border-radius: 50%;
      background: #fff; border: 3px solid var(--purple); cursor: pointer; box-shadow: 0 0 0 3px rgba(var(--accent-rgb),0.2); }
    input[type=range]::-moz-range-thumb { width: 15px; height: 15px; border-radius: 50%; background: #fff; border: 3px solid var(--purple); cursor: pointer; }
    .select {
      background: rgba(255,255,255,0.03); border: 1px solid var(--border); color: var(--text);
      border-radius: 9px; padding: 9px 11px; font-family: var(--font-body); font-size: 14px;
    }
    .select:focus { border-color: rgba(var(--accent-rgb),0.5); outline: none; }

    .readout {
      border: 1px solid var(--border); border-radius: 16px; padding: 22px 24px;
      background: rgba(255,255,255,0.02); transition: border-color .3s, background .3s;
    }
    .readout[data-q="persuadable"] { border-color: rgba(52,211,153,0.5); background: rgba(52,211,153,0.06); }
    .readout[data-q="sure"]        { border-color: rgba(var(--accent-rgb),0.4); background: rgba(var(--accent-rgb),0.05); }
    .readout[data-q="lost"]        { border-color: var(--border); }
    .readout[data-q="sleeping"]    { border-color: rgba(244,63,94,0.5); background: rgba(244,63,94,0.06); }
    .ro-quad { font-family: var(--font-display); font-weight: 700; font-size: clamp(23px, 3.4vw, 30px); letter-spacing: -0.02em; }
    .readout[data-q="persuadable"] .ro-quad { color: #34d399; }
    .readout[data-q="sleeping"] .ro-quad { color: #fb7185; }
    .readout[data-q="sure"] .ro-quad { color: var(--lilac); }
    .ro-action { font-size: 13px; color: var(--text-dim); line-height: 1.6; margin: 6px 0 18px; }
    .ro-nums { display: flex; gap: 12px; }
    .ro-col { flex: 1; }
    .ro-num { font-family: var(--font-display); font-weight: 700; font-size: clamp(19px, 2.6vw, 24px); line-height: 1; color: var(--text); }
    .ro-num.up.pos { color: #34d399; } .ro-num.up.neg { color: #fb7185; } .ro-num.up.flat { color: var(--muted); }
    .ro-cap { font-size: 10.5px; color: var(--muted); line-height: 1.3; margin-top: 4px; }

    /* Results */
    .results { margin-top: clamp(56px, 8vw, 92px); }
    .tiles { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin: 22px 0 34px; }
    .tile { border: 1px solid var(--border); border-radius: 14px; padding: 20px; background: rgba(255,255,255,0.02); }
    .tile-num { font-family: var(--font-display); font-weight: 700; font-size: clamp(26px, 3.4vw, 34px); color: var(--lilac); }
    .tile-cap { font-size: 12.5px; color: var(--muted); margin-top: 4px; }
    .tile-cap span { display: block; opacity: 0.7; font-size: 11px; }
    .charts { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
    .chart { border: 1px solid var(--border); border-radius: 14px; overflow: hidden; background: rgba(255,255,255,0.02); }
    .chart img { width: 100%; height: auto; display: block; }
    .svg-wrap { padding: 10px 10px 4px; }
    .svg-chart { width: 100%; height: auto; display: block; }
    :global(.svg-chart text) { font-family: var(--font-body); }
    :global(.svg-chart .ax-lbl) { fill: #bcaed4; font-size: 12.5px; }
    :global(.svg-chart .ax-tick) { fill: #a99bc0; font-size: 11px; }
    :global(.svg-chart .leg-txt), :global(.svg-chart .val-txt) { fill: #e2d7f0; font-size: 12px; font-family: var(--font-display); font-weight: 600; }
    :global(.svg-chart .bar) { transform: scaleY(0); transform-box: fill-box; transform-origin: bottom; }
    :global(.svg-chart.play .bar) { transform: scaleY(1); }
    :global(.svg-chart .fade) { opacity: 0; transition: opacity .6s ease .5s; }
    :global(.svg-chart.play .fade) { opacity: 1; }
    @media (prefers-reduced-motion: reduce) {
      :global(.svg-chart .bar) { transform: none; }
      :global(.svg-chart .fade) { opacity: 1; transition: none; }
    }
    .chart figcaption { font-size: 12.5px; color: var(--muted); padding: 10px 14px; border-top: 1px solid var(--border); line-height: 1.5; }
    .charts-note { margin-top: 18px; font-size: 13.5px; color: var(--muted); }
    .charts-note code { font-family: ui-monospace, monospace; color: var(--lilac); }

    /* Method */
    .method { margin-top: clamp(56px, 8vw, 92px); }
    .steps { margin: 18px 0 0; padding-left: 20px; display: flex; flex-direction: column; gap: 12px; color: var(--text-dim); font-weight: 300; line-height: 1.65; }
    .steps strong { color: var(--text); font-weight: 600; }
    .repo { margin-top: 32px; }
    .btn {
      display: inline-block; font-family: var(--font-display); font-weight: 600; font-size: 14px;
      padding: 12px 22px; border-radius: 10px; color: var(--text);
      border: 1px solid rgba(var(--accent-rgb),0.4); background: rgba(var(--accent-rgb),0.08); transition: all .25s;
