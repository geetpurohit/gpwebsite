---
import Base from '../../layouts/Base.astro';

const title = 'Credit-Default Scorecard | Geet Purohit';
const description =
  'An explainable credit-risk scorecard (WOE + logistic regression) benchmarked against an XGBoost challenger, with a live in-browser demo. Built on LendingClub loan-level data.';
---

<Base title={title} description={description}>
  <main class="cr">
    <div class="cr-container">
      <a class="back" href="/">← geetpurohit.com</a>

      <!-- ===== Header ===== -->
      <header class="cr-head reveal">
        <span class="section-label">Project · Credit Risk</span>
        <h1 class="cr-title">Credit-Default <span class="grad-text">Scorecard</span></h1>
        <p class="cr-lead">
          A loan-level model that estimates how likely a borrower is to default. I built it the way
          banks actually build credit models, with <strong>weight-of-evidence (WOE) binning and
          logistic regression</strong>, so every prediction can be explained. Then I benchmarked it
          against an <strong>XGBoost</strong> challenger with SHAP. It's trained on public
          <a href="https://www.kaggle.com/datasets/wordsforthewise/lending-club" target="_blank" rel="noopener">LendingClub</a>
          data, which stands in for the kind of proprietary credit-risk work I do day to day.
        </p>
        <div class="tags">
          <span class="tag">Python</span>
          <span class="tag">scikit-learn</span>
          <span class="tag">WOE / IV</span>
          <span class="tag">Logistic Regression</span>
          <span class="tag">XGBoost</span>
          <span class="tag">SHAP</span>
          <span class="tag">Calibration</span>
        </div>
      </header>

      <div id="placeholderBanner" class="banner" hidden>
        ⚠️ Demo is running on <strong>placeholder coefficients</strong>. Run
        <code>credit-risk-scorecard/train.py</code> to populate it with values learned from real data.
      </div>

      <!-- ===== Interactive demo ===== -->
      <section class="demo reveal" aria-labelledby="demoHead">
        <div class="demo-inner">
          <div class="demo-left">
            <h2 id="demoHead" class="block-h">Try it live</h2>
            <p class="block-sub">
              Adjust an applicant’s profile and the model scores it <em>right in your browser</em>,
              instantly. No server, nothing sent anywhere.
            </p>
            <form id="crForm" class="fields" autocomplete="off"><!-- inputs injected by JS --></form>
          </div>

          <div class="demo-right">
            <div class="gauge-card">
              <div class="gauge-label">Probability of default</div>
              <div id="prob" class="gauge-value">-</div>
              <div class="meter"><div id="meterFill" class="meter-fill"></div></div>
              <div class="score-row">
                <div><div id="score" class="score-num">-</div><div class="score-cap">Credit score</div></div>
                <div><div id="band" class="band">-</div><div class="score-cap">Risk band</div></div>
              </div>
            </div>

            <div class="contrib-card">
              <div class="contrib-head">
                <span>Why this score</span>
                <span class="contrib-key"><i class="dot up"></i>lowers risk&nbsp;&nbsp;<i class="dot down"></i>raises risk</span>
              </div>
              <div id="contrib" class="contrib-list"><!-- bars injected by JS --></div>
              <p class="contrib-foot">
                Each bar is that feature’s exact contribution to the score (points added or removed).
                Because the model is additive, the pieces add up to the total. It's the same idea as
                a SHAP explanation, just computed out in the open.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- ===== Results ===== -->
      <section class="results reveal">
        <h2 class="block-h">Model performance</h2>
        <div class="tiles">
          <div class="tile"><div id="mAuc" class="tile-num">-</div><div class="tile-cap">ROC-AUC <span>scorecard</span></div></div>
          <div class="tile"><div id="mKs" class="tile-num">-</div><div class="tile-cap">KS statistic</div></div>
          <div class="tile"><div id="mGini" class="tile-num">-</div><div class="tile-cap">Gini</div></div>
          <div class="tile"><div id="mXgb" class="tile-num">-</div><div class="tile-cap">ROC-AUC <span>XGBoost challenger</span></div></div>
        </div>

        <div class="charts">
          <figure class="chart"><div class="svg-wrap"><svg id="svgRoc" class="svg-chart" viewBox="0 0 620 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="ROC curve"></svg></div><figcaption>ROC: scorecard vs. challenger</figcaption></figure>
          <figure class="chart"><div class="svg-wrap"><svg id="svgCalib" class="svg-chart" viewBox="0 0 620 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Calibration curve"></svg></div><figcaption>Calibration: predicted vs. actual default rate</figcaption></figure>
          <figure class="chart"><div class="svg-wrap"><svg id="svgKs" class="svg-chart" viewBox="0 0 620 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="KS separation"></svg></div><figcaption>KS separation of goods vs. bads</figcaption></figure>
          <figure class="chart"><div class="svg-wrap"><svg id="svgIv" class="svg-chart" viewBox="0 0 620 400" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Information value by feature"></svg></div><figcaption>Predictive power (IV) by feature</figcaption></figure>
          <figure class="chart wide"><div class="svg-wrap"><svg id="svgShap" class="svg-chart" viewBox="0 0 1240 340" preserveAspectRatio="xMidYMid meet" role="img" aria-label="SHAP importance"></svg></div><figcaption>SHAP importance: mean impact of each feature in the XGBoost challenger</figcaption></figure>
        </div>
      </section>

      <!-- ===== Method ===== -->
      <section class="method reveal">
        <h2 class="block-h">How it works</h2>
        <ol class="steps">
          <li><strong>Label.</strong> Completed LendingClub loans are labelled default (charged-off) vs. paid; in-flight loans are dropped to avoid unknown outcomes.</li>
          <li><strong>WOE binning.</strong> Each feature is binned and mapped to its weight-of-evidence (the log-odds of good vs. bad), which linearises the relationship and keeps the model monotonic and easy to read.</li>
          <li><strong>Scorecard.</strong> A logistic regression on the WOE features produces calibrated probabilities, scaled into a familiar points-based credit score (PDO scaling).</li>
          <li><strong>Challenger + SHAP.</strong> An XGBoost model is trained as a performance ceiling; SHAP confirms the drivers agree with the scorecard’s logic.</li>
          <li><strong>Validation.</strong> Held-out ROC-AUC, KS, Gini, and a calibration curve, the metrics a model-risk review actually asks for.</li>
        </ol>
        <div class="repo">
          <a class="btn" href="https://github.com/geetpurohit" target="_blank" rel="noopener">View the code on GitHub →</a>
        </div>
      </section>
    </div>
  </main>

  <script>
    type Bin = { max: number | null; woe: number; label: string };
    type Cat = { value: string; label: string; woe: number };
    type Feature = {
      key: string; label: string; type: 'numeric' | 'categorical'; coef: number; iv: number;
      input: { min?: number; max?: number; step?: number; default: number | string };
      bins?: Bin[]; categories?: Cat[];
    };

    const $ = (id: string) => document.getElementById(id)!;
    const clamp = (v: number, a: number, b: number) => Math.max(a, Math.min(b, v));

    // ---- animated SVG charts (violet theme) ----
    const SVGNS = 'http://www.w3.org/2000/svg';
    function E(tag: string, attrs: Record<string, any>, parent?: Element): SVGElement {
      const e = document.createElementNS(SVGNS, tag);
      for (const k in attrs) e.setAttribute(k, String(attrs[k]));
      if (parent) parent.appendChild(e);
      return e as SVGElement;
    }
    const GEO = { W: 620, H: 400, l: 54, r: 20, t: 26, b: 46 };
    const lerp = (v: number, d0: number, d1: number, r0: number, r1: number) => r0 + (d1 === d0 ? 0 : (v - d0) / (d1 - d0)) * (r1 - r0);
    function frame(svg: SVGElement, xlabel: string, ylabel: string, H = GEO.H) {
      const { l, r, t, b, W } = GEO;
      E('line', { x1: l, y1: H - b, x2: W - r, y2: H - b, stroke: '#2a2440', 'stroke-width': 1 }, svg);
      E('line', { x1: l, y1: t, x2: l, y2: H - b, stroke: '#2a2440', 'stroke-width': 1 }, svg);
      if (xlabel) { const tx = E('text', { x: (l + W - r) / 2, y: H - 8, 'text-anchor': 'middle', class: 'ax-lbl' }, svg); tx.textContent = xlabel; }
      if (ylabel) { const ty = E('text', { x: 15, y: (t + H - b) / 2, 'text-anchor': 'middle', transform: `rotate(-90 15 ${(t + H - b) / 2})`, class: 'ax-lbl' }, svg); ty.textContent = ylabel; }
    }
    function yGrid(svg: SVGElement, ymin: number, ymax: number, fmt: (v: number) => string, n = 4, H = GEO.H) {
      const { l, r, t, b, W } = GEO;
      for (let i = 0; i <= n; i++) {
        const v = ymin + (ymax - ymin) * i / n, yy = lerp(v, ymin, ymax, H - b, t);
        E('line', { x1: l, y1: yy, x2: W - r, y2: yy, stroke: '#181327', 'stroke-width': 1 }, svg);
        const tk = E('text', { x: l - 8, y: yy + 3.5, 'text-anchor': 'end', class: 'ax-tick' }, svg); tk.textContent = fmt(v);
      }
    }
    function legend(svg: SVGElement, items: Array<[string, string]>) {
      const { l, t } = GEO; let x = l + 4;
      for (const [label, color] of items) {
        const g = E('g', {}, svg);
        E('rect', { x, y: t + 1, width: 14, height: 3, rx: 1.5, fill: color }, g);
        const tx = E('text', { x: x + 19, y: t + 7, class: 'leg-txt' }, g); tx.textContent = label;
        x += 19 + label.length * 6.4 + 16;
      }
    }
    const plays: Array<{ el: SVGElement; play: () => void; done: boolean }> = [];
    const onPlay = (svg: SVGElement, play: () => void) => plays.push({ el: svg, play, done: false });
    function drawReveal(svg: SVGElement, id: string, H = GEO.H) {
      const { l, r, t, b, W } = GEO;
      const cp = E('clipPath', { id }, svg);
      const rect = E('rect', { x: l, y: t - 6, width: 0, height: H - b - t + 12 }, cp);
      const g = E('g', { 'clip-path': `url(#${id})` }, svg);
      const run = () => { const full = W - r - l, dur = 1300, s = performance.now(); const step = (n: number) => { const p = Math.min(1, (n - s) / dur); rect.setAttribute('width', String(full * (1 - Math.pow(1 - p, 3)))); if (p < 1) requestAnimationFrame(step); }; requestAnimationFrame(step); };
      return { g, run };
    }
    function line(g: SVGElement, xs: number[], ys: number[], X: (v: number) => number, Y: (v: number) => number, color: string, w: number, dash?: string) {
      const d = xs.map((x, i) => (i ? 'L' : 'M') + X(x).toFixed(1) + ' ' + Y(ys[i]).toFixed(1)).join(' ');
      E('path', { d, fill: 'none', stroke: color, 'stroke-width': w, ...(dash ? { 'stroke-dasharray': dash } : {}) }, g);
    }
    // horizontal bar chart (bars grow from the left; wide left gutter for labels)
    function hbars(svg: SVGElement, labels: string[], values: number[], color: string, fmt: (v: number) => string, W = GEO.W, H = GEO.H) {
      const { r, t, b } = GEO;
      const L = 196;             // gutter wide enough for the longest feature names
      const xr = W - r - 50;     // room for the value label at the end of each bar
      const vmax = Math.max(...values) * 1.02 || 1;
      const n = labels.length, band = (H - b - t) / n;
      const X = (v: number) => lerp(v, 0, vmax, L, xr);
      E('line', { x1: L, y1: H - b, x2: W - r, y2: H - b, stroke: '#2a2440', 'stroke-width': 1 }, svg);
      E('line', { x1: L, y1: t, x2: L, y2: H - b, stroke: '#2a2440', 'stroke-width': 1 }, svg);
      labels.forEach((lab, i) => {
        const cy = t + band * (i + 0.5), bh = Math.min(22, band * 0.56);
        const rc = E('rect', { x: L + 1, y: cy - bh / 2, width: Math.max(1, X(values[i]) - L), height: bh, rx: 2, fill: color, class: 'hbar' }, svg);
        (rc as unknown as HTMLElement).style.transition = `transform .8s cubic-bezier(.2,.7,.3,1) ${i * 0.06}s`;
        const tl = E('text', { x: L - 10, y: cy + 3.5, 'text-anchor': 'end', class: 'hbar-lbl' }, svg); tl.textContent = lab;
        const vt = E('text', { x: X(values[i]) + 7, y: cy + 3.5, class: 'val-txt fade' }, svg); vt.textContent = fmt(values[i]);
      });
    }

    function renderCharts(c: any) {
      const { l, r, t, b, W, H } = GEO;

      // ROC — scorecard + challenger lines draw on, over the diagonal
      (() => {
        const svg = $('svgRoc') as unknown as SVGElement;
        yGrid(svg, 0, 1, (v) => v.toFixed(1));
        frame(svg, 'false positive rate', 'true positive rate');
        const X = (v: number) => lerp(v, 0, 1, l, W - r), Y = (v: number) => lerp(v, 0, 1, H - b, t);
        E('line', { x1: X(0), y1: Y(0), x2: X(1), y2: Y(1), stroke: '#4b4368', 'stroke-width': 1.2, 'stroke-dasharray': '3 4' }, svg);
        const { g, run } = drawReveal(svg, 'clipRoc');
        if (c.roc.xgb_fpr) line(g, c.roc.xgb_fpr, c.roc.xgb_tpr, X, Y, '#e879f9', 1.8, '7 5');
        line(g, c.roc.fpr, c.roc.tpr, X, Y, '#c084fc', 2.6);
        legend(svg, [['scorecard', '#c084fc'], ['XGBoost', '#e879f9']]);
        onPlay(svg, run);
      })();

      // Calibration — reliability line draws on, over the diagonal
      (() => {
        const svg = $('svgCalib') as unknown as SVGElement;
        yGrid(svg, 0, 1, (v) => v.toFixed(1));
        frame(svg, 'predicted default probability', 'observed default rate');
        const X = (v: number) => lerp(v, 0, 1, l, W - r), Y = (v: number) => lerp(v, 0, 1, H - b, t);
        E('line', { x1: X(0), y1: Y(0), x2: X(1), y2: Y(1), stroke: '#4b4368', 'stroke-width': 1.2, 'stroke-dasharray': '3 4' }, svg);
        const { g, run } = drawReveal(svg, 'clipCalib');
        line(g, c.calibration.mean_pred, c.calibration.frac_pos, X, Y, '#a855f7', 2.4);
        c.calibration.mean_pred.forEach((mp: number, i: number) => E('circle', { cx: X(mp), cy: Y(c.calibration.frac_pos[i]), r: 3.5, fill: '#c084fc', class: 'fade' }, svg));
        onPlay(svg, () => { svg.classList.add('play'); run(); });
      })();

      // KS — cumulative good/bad curves draw on, with the gap shaded
      (() => {
        const svg = $('svgKs') as unknown as SVGElement;
        const thr = c.ks.thr as number[], good = c.ks.good as number[], bad = c.ks.bad as number[];
        yGrid(svg, 0, 1, (v) => v.toFixed(1));
        frame(svg, 'score threshold (P default)', 'cumulative share');
        const X = (v: number) => lerp(v, 0, 1, l, W - r), Y = (v: number) => lerp(v, 0, 1, H - b, t);
        const area = 'M' + thr.map((x, i) => X(x).toFixed(1) + ' ' + Y(good[i]).toFixed(1)).join(' L ') +
          ' L' + thr.map((x, i) => X(thr[thr.length - 1 - i]).toFixed(1) + ' ' + Y(bad[bad.length - 1 - i]).toFixed(1)).join(' L ') + ' Z';
        E('path', { d: area, fill: 'rgba(168,85,247,0.12)', stroke: 'none', class: 'fade' }, svg);
        const { g, run } = drawReveal(svg, 'clipKs');
        line(g, thr, good, X, Y, '#34d399', 2.2);
        line(g, thr, bad, X, Y, '#f43f5e', 2.2);
        legend(svg, [['goods', '#34d399'], ['bads', '#f43f5e']]);
        onPlay(svg, () => { svg.classList.add('play'); run(); });
      })();

      // IV — horizontal bars grow from the left
      (() => {
        const svg = $('svgIv') as unknown as SVGElement;
        hbars(svg, c.iv.labels, c.iv.values, '#8b5cf6', (v) => v.toFixed(3));
        onPlay(svg, () => svg.classList.add('play'));
      })();

      // SHAP importance — wide banner, drawn at a wide viewBox so text stays crisp
      (() => {
        const svg = $('svgShap') as unknown as SVGElement;
        if (!c.shap) { (svg.closest('.chart') as HTMLElement).style.display = 'none'; return; }
        hbars(svg, c.shap.labels, c.shap.values, '#e879f9', (v) => v.toFixed(3), 1240, 340);
        onPlay(svg, () => svg.classList.add('play'));
      })();

      const io = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (!en.isIntersecting) return;
          const rec = plays.find((o) => o.el === en.target && !o.done);
          if (rec) { rec.done = true; rec.play(); }
          io.unobserve(en.target);
        });
      }, { threshold: 0.3 });
      plays.forEach((o) => io.observe(o.el));
    }

    async function main() {
      let data: any;
      try {
        const res = await fetch('/credit-risk/scorecard.json', { cache: 'no-cache' });
        data = await res.json();
      } catch {
        return;
      }

      const feats: Feature[] = data.features;

      // Placeholder notice
      if (typeof data.meta?.generated === 'string' && data.meta.generated.startsWith('placeholder')) {
        $('placeholderBanner').hidden = false;
      }

      // Metric tiles
      const pct = (x: number) => (x * 100).toFixed(1) + '%';
      $('mAuc').textContent = data.metrics?.scorecard?.auc?.toFixed(3) ?? '-';
      $('mKs').textContent = data.metrics?.scorecard?.ks != null ? pct(data.metrics.scorecard.ks) : '-';
      $('mGini').textContent = data.metrics?.scorecard?.gini?.toFixed(3) ?? '-';
      $('mXgb').textContent = data.metrics?.xgboost?.auc?.toFixed(3) ?? '-';

      if (data.charts) renderCharts(data.charts);

      // Build inputs
      const form = $('crForm');
      form.innerHTML = feats.map((f) => {
        if (f.type === 'numeric') {
          const i = f.input;
          return `<label class="field">
            <span class="field-top"><span>${f.label}</span><output id="out_${f.key}"></output></span>
            <input type="range" id="in_${f.key}" min="${i.min}" max="${i.max}" step="${i.step}" value="${i.default}" />
          </label>`;
        }
        const opts = (f.categories || []).map((c) => `<option value="${c.value}">${c.label}</option>`).join('');
        return `<label class="field">
          <span class="field-top"><span>${f.label}</span></span>
          <select id="in_${f.key}" class="select">${opts}</select>
        </label>`;
      }).join('');

      feats.forEach((f) => {
        const el = $('in_' + f.key) as HTMLInputElement;
        if (f.type === 'categorical') el.value = String(f.input.default);
        el.addEventListener('input', compute);
      });

      const fmtVal = (f: Feature, v: number) => {
        if (f.key === 'annual_inc' || f.key === 'loan_amnt') return '$' + Math.round(v).toLocaleString();
        if (f.key === 'dti' || f.key === 'revol_util') return v + '%';
        if (f.key === 'emp_length') return v + ' yr';
        return String(v);
      };

      const woeNumeric = (f: Feature, v: number) => {
        for (const b of f.bins!) if (b.max === null || v <= b.max) return b.woe;
        return f.bins![f.bins!.length - 1].woe;
      };
      const woeCateg = (f: Feature, v: string) => {
        const c = (f.categories || []).find((c) => c.value === v);
        return c ? c.woe : 0;
      };

      function compute() {
        const sc = data.scaling;
        let logit = data.intercept as number;
        const contribs: { label: string; points: number }[] = [];

        for (const f of feats) {
          const el = $('in_' + f.key) as HTMLInputElement;
          let woe = 0, shown = '';
          if (f.type === 'numeric') {
            const v = parseFloat(el.value);
            woe = woeNumeric(f, v);
            shown = fmtVal(f, v);
            const o = document.getElementById('out_' + f.key);
            if (o) o.textContent = shown;
          } else {
            woe = woeCateg(f, el.value);
          }
          const c = f.coef * woe;             // contribution to default log-odds
          logit += c;
          contribs.push({ label: f.label, points: sc.factor * -c }); // +points => safer
        }

        const prob = 1 / (1 + Math.exp(-logit));
        const score = Math.round(sc.offset + sc.factor * -logit);

        $('prob').textContent = (prob * 100).toFixed(1) + '%';
        $('score').textContent = String(score);
        ($('meterFill') as HTMLElement).style.width = clamp(prob * 100 * 2.2, 3, 100) + '%';

        const band = prob < 0.08 ? 'Low' : prob < 0.16 ? 'Moderate' : prob < 0.28 ? 'Elevated' : 'High';
        const bandEl = $('band');
        bandEl.textContent = band;
        bandEl.className = 'band b-' + band.toLowerCase();
        ($('meterFill') as HTMLElement).dataset.band = band.toLowerCase();

        // contribution bars
        const maxAbs = Math.max(...contribs.map((c) => Math.abs(c.points)), 1);
        contribs.sort((a, b) => Math.abs(b.points) - Math.abs(a.points));
        $('contrib').innerHTML = contribs.map((c) => {
          const w = (Math.abs(c.points) / maxAbs) * 100;
          const dir = c.points >= 0 ? 'up' : 'down';
          const side = c.points >= 0 ? 'pos' : 'neg';
          return `<div class="crow">
            <span class="clabel">${c.label}</span>
            <span class="cbar"><span class="cfill ${side}" style="width:${w.toFixed(0)}%"></span></span>
            <span class="cval ${dir}">${c.points >= 0 ? '+' : ''}${Math.round(c.points)}</span>
          </div>`;
        }).join('');
      }

      compute();
    }

    main();
  </script>

  <style>
    .cr { position: relative; z-index: 2; padding: clamp(28px, 6vw, 64px) var(--pad-x) 120px; }
    .cr-container { width: 100%; max-width: 1080px; margin-inline: auto; }
    .back {
      display: inline-block; font-family: var(--font-display); font-size: 13px;
      color: var(--muted); margin-bottom: clamp(32px, 6vw, 56px); transition: color .25s;
    }
    .back:hover { color: var(--lilac); }

    .cr-title {
      font-family: var(--font-display); font-weight: 700;
      font-size: clamp(34px, 6vw, 68px); letter-spacing: -0.03em; line-height: 1.02; margin-bottom: 22px;
    }
    .cr-lead { font-size: clamp(16.5px, 1.3vw, 19px); color: var(--text-dim); font-weight: 300; line-height: 1.8; max-width: 780px; }
    .cr-lead strong { color: var(--text); font-weight: 500; }
    .cr-lead a { color: var(--purple-lt); text-decoration: underline; text-underline-offset: 2px; }
    .tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 26px; }
    .tag {
      font-family: var(--font-display); font-size: 12px; padding: 5px 13px; border-radius: 7px;
      background: rgba(168,85,247,0.05); border: 1px solid var(--border); color: var(--text-dim);
    }

    .banner {
      margin: 28px 0 0; padding: 13px 18px; border-radius: 11px; font-size: 14px; color: var(--lilac);
      background: rgba(232,121,249,0.06); border: 1px solid rgba(232,121,249,0.24);
    }
    .banner code { font-family: ui-monospace, monospace; color: var(--magenta); }

